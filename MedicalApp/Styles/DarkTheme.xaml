<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Dark Theme Color Palette -->
    <SolidColorBrush x:Key="PrimaryColor" Color="#14B8A6"/> <!-- Teal 500 -->
    <SolidColorBrush x:Key="PrimaryHoverColor" Color="#0D9488"/> <!-- Teal 600 -->
    <SolidColorBrush x:Key="SecondaryColor" Color="#38BDF8"/> <!-- Sky 400 -->
    <SolidColorBrush x:Key="BackgroundColor" Color="#0F172A"/> <!-- Slate 900 -->
    <SolidColorBrush x:Key="CardBackgroundColor" Color="#1E293B"/> <!-- Slate 800 -->
    <SolidColorBrush x:Key="TextColor" Color="#F8FAFC"/> <!-- Slate 50 -->
    <SolidColorBrush x:Key="SubtextColor" Color="#94A3B8"/> <!-- Slate 400 -->
    <SolidColorBrush x:Key="BorderColor" Color="#334155"/> <!-- Slate 700 -->
    <SolidColorBrush x:Key="AccentColor" Color="#FB7185"/> <!-- Rose 400 -->
    <SolidColorBrush x:Key="SelectedTabBrush" Color="#115E59"/> <!-- Teal 800 -->
    <SolidColorBrush x:Key="SelectedTabTextBrush" Color="#2DD4BF"/> <!-- Teal 400 -->
 
    <!-- Material Design Theme Compatibility Brushes (Legacy and Modern) -->
    <SolidColorBrush x:Key="MaterialDesignPaper" Color="#1E293B"/>
    <SolidColorBrush x:Key="MaterialDesignBackground" Color="#0F172A"/>
    <SolidColorBrush x:Key="MaterialDesignCardBackground" Color="#1E293B"/>
    <SolidColorBrush x:Key="MaterialDesignBody" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="MaterialDesignBodyLight" Color="#94A3B8"/>
    <SolidColorBrush x:Key="MaterialDesignTextBoxBorder" Color="#334155"/>
 
    <SolidColorBrush x:Key="MaterialDesign.Brush.Paper" Color="#1E293B"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.Background" Color="#0F172A"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.Card.Background" Color="#1E293B"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.Surface" Color="#1E293B"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.SurfaceVariant" Color="#0F172A"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.Body" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.OnSurface" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.OnSurfaceVariant" Color="#94A3B8"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.OnBackground" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.Text" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.Foreground" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.TextBox.Border" Color="#334155"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.Primary" Color="#14B8A6"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.Secondary" Color="#38BDF8"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.Text.Primary" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.Text.Secondary" Color="#94A3B8"/>

    <!-- Control-specific MD3 Brushes -->
    <SolidColorBrush x:Key="MaterialDesign.Brush.TextBox.Foreground" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.TextBox.Background" Color="Transparent"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.TextBox.Hint" Color="#94A3B8"/>

    <SolidColorBrush x:Key="MaterialDesign.Brush.ComboBox.Foreground" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.ComboBox.Background" Color="Transparent"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.ComboBox.Hint" Color="#94A3B8"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.ComboBox.Border" Color="#334155"/>

    <SolidColorBrush x:Key="MaterialDesign.Brush.DatePicker.Foreground" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.DatePicker.Background" Color="Transparent"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.DatePicker.Hint" Color="#94A3B8"/>
    <SolidColorBrush x:Key="MaterialDesign.Brush.DatePicker.Border" Color="#334155"/>

    <!-- Highlight and Active Session Cards -->
    <SolidColorBrush x:Key="HighlightCardBackground" Color="#451A03"/> <!-- Dark Amber -->
    <SolidColorBrush x:Key="HighlightCardBorder" Color="#78350F"/> <!-- Amber 800 -->
    <SolidColorBrush x:Key="HighlightCardText" Color="#FBBF24"/> <!-- Amber 400 -->
    <SolidColorBrush x:Key="HighlightCardSubtext" Color="#F59E0B"/> <!-- Amber 500 -->

    <!-- Informational Alert Cards -->
    <SolidColorBrush x:Key="InfoAlertBackground" Color="#172554"/> <!-- Dark Blue -->
    <SolidColorBrush x:Key="InfoAlertBorder" Color="#1E3A8A"/> <!-- Blue 800 -->
    <SolidColorBrush x:Key="InfoAlertText" Color="#60A5FA"/> <!-- Blue 400 -->
    <SolidColorBrush x:Key="InfoAlertSubtext" Color="#93C5FD"/> <!-- Blue 300 -->
    <SolidColorBrush x:Key="InfoAlertIcon" Color="#3B82F6"/> <!-- Blue 50 -->

    <!-- Status Badges -->
    <SolidColorBrush x:Key="SuccessBadgeBackground" Color="#064E3B"/> <!-- Dark Green -->
    <SolidColorBrush x:Key="SuccessBadgeText" Color="#34D399"/> <!-- Green 400 -->
    <SolidColorBrush x:Key="InfoBadgeBackground" Color="#0C4A6E"/> <!-- Dark Blue -->
    <SolidColorBrush x:Key="InfoBadgeText" Color="#38BDF8"/> <!-- Blue 400 -->
    <SolidColorBrush x:Key="WarningBadgeBackground" Color="#7F1D1D"/> <!-- Dark Red -->
    <SolidColorBrush x:Key="WarningBadgeText" Color="#FCA5A5"/> <!-- Red 400 -->
</ResourceDictionary>
