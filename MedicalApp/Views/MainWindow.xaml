<ui:FluentWindow x:Class="MedicalApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:MedicalApp.Converters"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="LAN Medical Client-Server Portal" Height="780" Width="1240"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="{DynamicResource BackgroundColor}">
    
    <Window.Resources>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <!-- Main Workspace -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- TitleBar -->
                <RowDefinition Height="Auto"/>  <!-- Header Banner -->
                <RowDefinition Height="*"/>     <!-- Active View Content -->
            </Grid.RowDefinitions>

            <!-- Custom Fluent TitleBar -->
            <ui:TitleBar Grid.Row="0" Title="LAN Medical Client-Server Portal" Margin="0" Height="32"/>

            <!-- Global Patient Header Banner -->
            <Border Grid.Row="1" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHomeActive}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsClinicalExamActive}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Margin="25,0" Height="70">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/> <!-- Connection Badge -->
                        <ColumnDefinition Width="Auto"/> <!-- Theme Toggle -->
                    </Grid.ColumnDefinitions>

                    <!-- Selected Patient Info -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="Active Patient: " FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource SubtextColor}"/>
                        <TextBlock Text="{Binding SelectedPatient.Name, TargetNullValue='No Patient Selected'}" 
                                   FontSize="15" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" Margin="5,0,0,0"/>
                        
                        <StackPanel Orientation="Horizontal" Visibility="{Binding SelectedPatient, Converter={StaticResource NullToVisibilityConverter}}" Margin="20,0,0,0">
                            <TextBlock Text="Age: " FontSize="14" Foreground="{DynamicResource SubtextColor}"/>
                            <TextBlock Text="{Binding SelectedPatient.Age}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextColor}" Margin="2,0,15,0"/>
                            <TextBlock Text="Gender: " FontSize="14" Foreground="{DynamicResource SubtextColor}"/>
                            <TextBlock Text="{Binding SelectedPatient.Gender}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextColor}" Margin="2,0,15,0"/>
                            <TextBlock Text="Phone: " FontSize="14" Foreground="{DynamicResource SubtextColor}"/>
                            <TextBlock Text="{Binding SelectedPatient.Phone}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextColor}" Margin="2,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Connection Badge -->
                    <Border Grid.Column="1" VerticalAlignment="Center" Background="{DynamicResource InfoBadgeBackground}" Padding="10,5" CornerRadius="6">
                        <TextBlock Text="Database Connected" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource InfoBadgeText}"/>
                    </Border>

                    <!-- Theme Toggle -->
                    <Button Grid.Column="2" Width="36" Height="36" Padding="0" VerticalAlignment="Center" Margin="15,0,0,0"
                            Command="{Binding ToggleThemeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                <Setter Property="Tag" Value="&#xE708;"/> <!-- Moon icon -->
                                <Setter Property="ToolTip" Value="Switch to Dark Mode"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                        <Setter Property="Tag" Value="&#xE706;"/> <!-- Sun icon -->
                                        <Setter Property="ToolTip" Value="Switch to Light Mode"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Routed view content -->
            <ContentControl Grid.Row="2" Content="{Binding CurrentView}" Margin="12"/>
        </Grid>
    </Grid>
</ui:FluentWindow>
