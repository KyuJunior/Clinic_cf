<Window x:Class="MedicalApp.Views.ImagePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Preview | معاينة الصورة" 
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#E60F172A"
        KeyDown="Window_KeyDown"
        MouseDown="Window_MouseDown">
    <Grid>
        <Image Name="PreviewImage" Stretch="Uniform" Margin="40"/>
        
        <!-- Close Button in Top-Right -->
        <Button Content="✕" 
                Click="CloseButton_Click" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Margin="30"
                FontSize="24"
                Foreground="#94A3B8"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Width="48"
                Height="48">
            <Button.Resources>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="24">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#334155"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Resources>
        </Button>
        
        <TextBlock Text="انقر في أي مكان أو اضغط ESC للإغلاق | Click anywhere or press ESC to close" 
                   Foreground="#64748B" 
                   FontSize="13" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Bottom" 
                   Margin="30"/>
    </Grid>
</Window>
