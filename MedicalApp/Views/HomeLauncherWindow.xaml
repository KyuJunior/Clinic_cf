<Window x:Class="MedicalApp.Views.HomeLauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="My Clinic - Launcher Portal" Height="520" Width="1020"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundColor}">
    
    <Window.Resources>
        <!-- Custom card style with hover effects and glassmorphic gradient look -->
        <Style x:Key="LauncherCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#0F172A" Opacity="0.08" BlurRadius="25" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="{DynamicResource CardBackgroundColorVal}" Offset="0"/>
                                <GradientStop Color="{DynamicResource SelectedTabBrushVal}" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="{DynamicResource PrimaryColorVal}" Opacity="0.12" BlurRadius="30" ShadowDepth="4" Direction="270"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Gradient Accent Button -->
        <Style x:Key="GradientModernButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{DynamicResource SecondaryColorVal}" Offset="0"/>
                        <GradientStop Color="{DynamicResource PrimaryColorVal}" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" 
                                Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>  <!-- Top Banner -->
            <RowDefinition Height="*"/>   <!-- Room Selection Cards Grid -->
            <RowDefinition Height="32"/>  <!-- Status Footer -->
        </Grid.RowDefinitions>

        <!-- Top Pink/Teal Header Banner -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid Margin="25,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="My" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}"/>
                    <TextBlock Text="Clinic" FontSize="20" FontWeight="Light" Foreground="{DynamicResource PrimaryColor}" Margin="2,0,0,0"/>
                    <Border Background="{DynamicResource SelectedTabBrush}" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Launcher Portal" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SelectedTabTextBrush}"/>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1" VerticalAlignment="Center" Background="{DynamicResource SuccessBadgeBackground}" Padding="10,5" CornerRadius="6">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBadgeText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Database Connected" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBadgeText}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Room Selection Cards Grid -->
        <Grid Grid.Row="1" Margin="15,20,15,10" MaxWidth="760" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300" MaxWidth="340"/>
                <ColumnDefinition Width="*" MinWidth="300" MaxWidth="340"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Patient Registry (Secretary) -->
            <Border Grid.Column="0" Style="{StaticResource LauncherCardStyle}" Margin="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Icon -->
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="*"/>    <!-- Description -->
                        <RowDefinition Height="Auto"/> <!-- Enter Button -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{DynamicResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,10,0,20"/>
                    
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="Secretary Room" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextColor}" HorizontalAlignment="Center"/>
                        <TextBlock Text="غرفة السكرتارية" FontSize="12" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="Enroll new patients, search existing records using autocomplete lookup, and queue them to today's active waitlist." 
                               FontSize="12.5" Foreground="{DynamicResource SubtextColor}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="18" Margin="0,5,0,25"/>
                    
                    <Button Grid.Row="3" Style="{StaticResource GradientModernButton}" Content="Open Secretary Window" Command="{Binding LaunchRegistryCommand}" Height="40" HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- Card 2: Doctor Room -->
            <Border Grid.Column="1" Style="{StaticResource LauncherCardStyle}" Margin="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Icon -->
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="*"/>    <!-- Description -->
                        <RowDefinition Height="Auto"/> <!-- Enter Button -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="&#xE1E2;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{DynamicResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,10,0,20"/>
                    
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="Doctor Room" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextColor}" HorizontalAlignment="Center"/>
                        <TextBlock Text="عيادة الطبيب" FontSize="12" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="Manage waitlisted patients in real-time, record complaints/diagnoses, and direct patients to completed status." 
                               FontSize="12.5" Foreground="{DynamicResource SubtextColor}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="18" Margin="0,5,0,25"/>
                    
                    <Button Grid.Row="3" Style="{StaticResource GradientModernButton}" Content="Open Doctor Window" Command="{Binding LaunchExamCommand}" Height="40" HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Footer -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="15,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="My Clinic Launcher Portal" FontSize="10" Foreground="{DynamicResource SubtextColor}"/>
                <TextBlock Grid.Column="1" Text="{Binding ConnectionInfo, StringFormat='Active Node: \{0\}'}" FontSize="10" Foreground="{DynamicResource SubtextColor}" FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</Window>
