<UserControl x:Class="MedicalApp.Views.PatientRegistrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:MedicalApp.Converters"
             xmlns:helpers="clr-namespace:MedicalApp.Helpers"
             xmlns:views="clr-namespace:MedicalApp.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="Transparent">
    
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:ZeroToEmptyConverter x:Key="ZeroToEmptyConverter"/>
        <views:BindingProxy x:Key="Proxy" Data="{Binding}"/>

        <!-- Custom Green Toggle Switch Style matching mockup -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Grid x:Name="Border" Width="38" Height="20">
                                    <Border x:Name="Background" CornerRadius="10" Background="#E2E8F0" BorderThickness="0"/>
                                    <Border x:Name="Thumb" Width="16" Height="16" CornerRadius="8" Background="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="4" Color="Black" Opacity="0.15" ShadowDepth="1"/>
                                        </Border.Effect>
                                    </Border>
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="Background" Property="Background" Value="#10B981"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <!-- Main Grid Layout (Left Sidebar + Main Area) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/> <!-- Left Sidebar: Queue / Waitlist -->
                <ColumnDefinition Width="*"/>   <!-- Right Content: Stats & Table -->
            </Grid.ColumnDefinitions>

            <!-- Column 0: Left Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1.5,0">
                <Grid Margin="10,15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>    <!-- Waiting Visits -->
                        <RowDefinition Height="*"/>    <!-- Incomplete Visits -->
                    </Grid.RowDefinitions>

                    <!-- Row 0: Waiting Visits -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,10" HorizontalAlignment="Left">
                            <TextBlock Text="Waiting Queue" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}"/>
                            <TextBlock Text="الزيارات المنتظرة" FontSize="10" Foreground="{DynamicResource SubtextColor}" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Waitlist Queue List -->
                        <ListBox Grid.Row="1" ItemsSource="{Binding WaitingVisits}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,6" Background="{DynamicResource CardBackgroundColor}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/> <!-- Time -->
                                                <ColumnDefinition Width="*"/>    <!-- Name -->
                                                <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Time -->
                                            <TextBlock Grid.Column="0" Text="{Binding CreatedAt, StringFormat=\{0:hh:mm tt\}}" FontSize="9.5" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryColor}" VerticalAlignment="Center"/>

                                            <!-- Name and Doctor Name -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                                <TextBlock Text="{Binding PatientName}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource TextColor}" TextWrapping="Wrap" TextAlignment="Left"/>
                                                <TextBlock Text="{Binding DoctorName, StringFormat='with {0}'}" FontSize="10" Foreground="{DynamicResource SubtextColor}" TextAlignment="Left" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Status Icon -->
                                            <TextBlock Grid.Column="2" Text="&#xE814;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <!-- Row 1: Incomplete Visits -->
                    <Border Grid.Row="1" Margin="0,10,0,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,10" HorizontalAlignment="Left">
                                <TextBlock Text="Active Consultations" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}"/>
                                <TextBlock Text="الزيارات غير المنتهية" FontSize="10" Foreground="{DynamicResource SubtextColor}" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Incomplete Queue List -->
                            <ListBox Grid.Row="1" ItemsSource="{Binding IncompleteVisits}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,6" Background="{DynamicResource CardBackgroundColor}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/> <!-- Time -->
                                                    <ColumnDefinition Width="*"/>    <!-- Name -->
                                                    <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                                </Grid.ColumnDefinitions>

                                                <!-- Time -->
                                                <TextBlock Grid.Column="0" Text="{Binding CreatedAt, StringFormat=\{0:hh:mm tt\}}" FontSize="9.5" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryColor}" VerticalAlignment="Center"/>

                                                <!-- Name and Doctor Name -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                                    <TextBlock Text="{Binding PatientName}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource AccentColor}" TextWrapping="Wrap" TextAlignment="Left"/>
                                                    <TextBlock Text="{Binding DoctorName, StringFormat='in session with {0}'}" FontSize="10" Foreground="{DynamicResource SubtextColor}" TextAlignment="Left" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <!-- Status Icon (In Session) -->
                                                <TextBlock Grid.Column="2" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Column 1: Main Area -->
            <Grid Grid.Column="1" Margin="15,15,15,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- Main View Content Area -->
                    <RowDefinition Height="Auto"/> <!-- Bottom Floating Bar -->
                </Grid.RowDefinitions>

                <!-- Main View Content Area (Grid Row 0) -->
                <Grid Grid.Row="0">
                    
                    <!-- Panel 0: Dashboard (KPI Cards Grid) -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSubView}" Value="Dashboard">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        
                        <!-- Center the 2x3 grid (2 columns, 3 rows) of KPI cards vertically -->
                        <UniformGrid Columns="2" Rows="3" VerticalAlignment="Center" Margin="20,10" MaxWidth="900" Height="480">

                            <!-- Card 0: Total Registered (Clickable Card) -->
                            <Button Command="{Binding ShowAllPatientsViewCommand}" Margin="8" Cursor="Hand" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="10" Padding="18,16">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#0D9488" Offset="0"/> <!-- Teal 600 -->
                                                    <GradientStop Color="#2DD4BF" Offset="1"/> <!-- Teal 400 -->
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#0F172A" Opacity="0.12" BlurRadius="12" ShadowDepth="1.5" Direction="270"/>
                                            </Border.Effect>
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White" Opacity="0.8" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        <TextBlock Text="إجمالي المرضى المسجلين" FontSize="13.5" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Text="{Binding TotalPatientsCount}" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,8,0,6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="Total Registered Patients (Click to View)" FontSize="10.5" Foreground="White" Opacity="0.85" HorizontalAlignment="Left"/>
                                </Grid>
                            </Button>

                            <!-- Card 1: New Patients -->
                            <Border CornerRadius="10" Padding="18,16" Margin="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4F46E5" Offset="0"/> <!-- Indigo 600 -->
                                        <GradientStop Color="#818CF8" Offset="1"/> <!-- Indigo 400 -->
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#0F172A" Opacity="0.12" BlurRadius="12" ShadowDepth="1.5" Direction="270"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="&#xE8FA;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White" Opacity="0.8" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        <TextBlock Text="المرضى الجدد اليوم" FontSize="13.5" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Text="{Binding NewPatientsTodayCount}" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,8,0,6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="New Patients Registered Today" FontSize="10.5" Foreground="White" Opacity="0.85" HorizontalAlignment="Left"/>
                                </Grid>
                            </Border>

                            <!-- Card 2: Waiting Patients -->
                            <Border CornerRadius="10" Padding="18,16" Margin="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0284C7" Offset="0"/> <!-- Sky 700 -->
                                        <GradientStop Color="#38BDF8" Offset="1"/> <!-- Sky 400 -->
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#0F172A" Opacity="0.12" BlurRadius="12" ShadowDepth="1.5" Direction="270"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White" Opacity="0.8" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        <TextBlock Text="المرضى في الانتظار" FontSize="13.5" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Text="{Binding WaitingPatientsCount}" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,8,0,6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="Waiting Patients in Queue" FontSize="10.5" Foreground="White" Opacity="0.85" HorizontalAlignment="Left"/>
                                </Grid>
                            </Border>

                            <!-- Card 3: Active Consultations -->
                            <Border CornerRadius="10" Padding="18,16" Margin="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E11D48" Offset="0"/> <!-- Rose 600 -->
                                        <GradientStop Color="#F43F5E" Offset="1"/> <!-- Rose 400 -->
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#0F172A" Opacity="0.12" BlurRadius="12" ShadowDepth="1.5" Direction="270"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="&#xE957;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White" Opacity="0.8" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        <TextBlock Text="الزيارات غير المنتهية" FontSize="13.5" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Text="{Binding IncompleteVisitsCount}" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,8,0,6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="Active Unfinished Visits" FontSize="10.5" Foreground="White" Opacity="0.85" HorizontalAlignment="Left"/>
                                </Grid>
                            </Border>

                            <!-- Card 4: Patient in Exam Room -->
                            <Border CornerRadius="10" Padding="18,16" Margin="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#D97706" Offset="0"/> <!-- Amber 600 -->
                                        <GradientStop Color="#F59E0B" Offset="1"/> <!-- Amber 400 -->
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#0F172A" Opacity="0.12" BlurRadius="12" ShadowDepth="1.5" Direction="270"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White" Opacity="0.8" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        <TextBlock Text="المريض في غرفة الطبيب" FontSize="13.5" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Text="{Binding PatientInDoctorRoomName}" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,10,0,6" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" ToolTip="{Binding PatientInDoctorRoomName}"/>
                                    <TextBlock Grid.Row="2" Text="Patient with Attending Doctor" FontSize="10.5" Foreground="White" Opacity="0.85" HorizontalAlignment="Left"/>
                                </Grid>
                            </Border>

                            <!-- Card 5: Next Patient -->
                            <Border CornerRadius="10" Padding="18,16" Margin="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C3AED" Offset="0"/> <!-- Purple 600 -->
                                        <GradientStop Color="#A855F7" Offset="1"/> <!-- Violet 400 -->
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#0F172A" Opacity="0.12" BlurRadius="12" ShadowDepth="1.5" Direction="270"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="&#xE893;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White" Opacity="0.8" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        <TextBlock Text="المريض التالي" FontSize="13.5" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Text="{Binding NextPatientName}" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,10,0,6" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" ToolTip="{Binding NextPatientName}"/>
                                    <TextBlock Grid.Row="2" Text="Next Patient in Queue" FontSize="10.5" Foreground="White" Opacity="0.85" HorizontalAlignment="Left"/>
                                </Grid>
                            </Border>
                        </UniformGrid>
                    </Grid>

                    <!-- Panels container border (for AllPatients, TodayVisits, AppointmentsCalendar, Finance) -->
                    <!-- We only show this border if ActiveSubView is NOT "Dashboard" -->
                    <Border Padding="15">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource CardBorder}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSubView}" Value="Dashboard">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                        <!-- Panel 1: All Patients -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveSubView}" Value="AllPatients">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Search bar -->
                                <RowDefinition Height="*"/>    <!-- DataGrid -->
                            </Grid.RowDefinitions>

                        <!-- Search Bar -->
                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- Settings Gear -->
                                <ColumnDefinition Width="*"/>    <!-- Search Box -->
                                <ColumnDefinition Width="Auto"/> <!-- Filters Toggle -->
                                <ColumnDefinition Width="Auto"/> <!-- Search Button -->
                                <ColumnDefinition Width="Auto"/> <!-- Manage Doctors -->
                            </Grid.ColumnDefinitions>

                            <!-- Settings Gear Button for Grid Columns -->
                            <Grid Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Button Style="{StaticResource NavButton}" Content="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource SubtextColor}" Command="{Binding ToggleGridGearCommand}"/>
                                
                                <!-- 3-Column Popup switches list to control all column visibilities -->
                                <Popup IsOpen="{Binding IsGridGearOpen, Mode=TwoWay}" StaysOpen="False" Placement="Bottom">
                                    <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="8" Padding="15" Width="620">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.15" ShadowDepth="3"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="إعدادات أعمدة الجدول (عرض / إخفاء)" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,10" HorizontalAlignment="Right"/>
                                            
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Left Column (Column 0) -->
                                                <StackPanel Grid.Column="0" Margin="0,0,10,0" FlowDirection="RightToLeft">
                                                    <CheckBox Content="الرمز" IsChecked="{Binding ShowPatientId}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="الاسم" IsChecked="{Binding ShowName}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="العمر" IsChecked="{Binding ShowAge}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="الجنس" IsChecked="{Binding ShowGender}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="العمل" IsChecked="{Binding ShowJob}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="العنوان" IsChecked="{Binding ShowAddress}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="ملاحظات" IsChecked="{Binding ShowNotes}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="الحساسية" IsChecked="{Binding ShowAllergy}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                </StackPanel>

                                                <!-- Middle Column (Column 1) -->
                                                <StackPanel Grid.Column="1" Margin="10,0,10,0" FlowDirection="RightToLeft">
                                                    <CheckBox Content="المحافظة" IsChecked="{Binding ShowGovernorate}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="رقم الهاتف" IsChecked="{Binding ShowPhone}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="الوزن" IsChecked="{Binding ShowWeight}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="الطول" IsChecked="{Binding ShowHeight}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="الحالة الزوجية" IsChecked="{Binding ShowMaritalStatus}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="اسم الزوج/ة" IsChecked="{Binding ShowSpouseName}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="هل يوجد اطفال" IsChecked="{Binding ShowHasChildren}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                </StackPanel>

                                                <!-- Right Column (Column 2) -->
                                                <StackPanel Grid.Column="2" Margin="10,0,0,0" FlowDirection="RightToLeft">
                                                    <CheckBox Content="فصيلة الدم" IsChecked="{Binding ShowBloodGroup}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="التدخين" IsChecked="{Binding ShowSmoking}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="الكحول" IsChecked="{Binding ShowAlcohol}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="من طرف" IsChecked="{Binding ShowReferredBy}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="تاريخ المراجعة" IsChecked="{Binding ShowReturnDate}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="اخر زيارة" IsChecked="{Binding ShowLastVisit}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="عدد الزيارات" IsChecked="{Binding ShowVisitsCount}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="تاريخ الزواج" IsChecked="{Binding ShowMarriageDate}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="تاريخ ولادة الزوج/ة" IsChecked="{Binding ShowSpouseBirthDate}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="فصيلة دم الزوج/ة" IsChecked="{Binding ShowSpouseBloodGroup}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                    <CheckBox Content="تاريخ ولادة اخر طفل" IsChecked="{Binding ShowLastChildBirthDate}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Save Button -->
                                            <ui:Button Grid.Row="2" Appearance="Primary" Content="حفظ كافتراضي" Command="{Binding SavePreferencesCommand}" HorizontalAlignment="Center" Margin="0,15,0,0" Padding="30,6" Height="32" FontSize="12"/>
                                        </Grid>
                                    </Border>
                                </Popup>
                            </Grid>

                            <ui:TextBox Grid.Column="1" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="بحث باسم المريض أو رقم الهاتف..." Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Command="{Binding ToggleFiltersSidebarCommand}" Width="36" Height="36" Margin="0,0,10,0" ToolTip="تصفية متقدمة">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                        <Setter Property="Tag" Value="&#xE71C;"/> <!-- Filter icon -->
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFiltersSidebarOpen}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SelectedTabBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SelectedTabTextBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <ui:Button Grid.Column="3" Appearance="Primary" Content="بحث" Command="{Binding SearchCommand}" Padding="20,8"/>
                            <ui:Button Grid.Column="4" Appearance="Secondary" Content="إدارة الأطباء | Manage Doctors" Height="36" Margin="10,0,0,0" Command="{Binding OpenDoctorsModalCommand}"/>
                        </Grid>

                        <!-- DataGrid Table with Collapsible Sidebar -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- Sidebar -->
                                <ColumnDefinition Width="*"/>    <!-- Content Table -->
                            </Grid.ColumnDefinitions>

                            <!-- Collapsible Filters Sidebar (RTL flow direction, so it will slide from right side of the screen) -->
                            <Border Grid.Column="0" Width="260" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1,0,0,0" CornerRadius="8" Padding="15" Margin="0,0,15,0"
                                    Visibility="{Binding IsFiltersSidebarOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel FlowDirection="RightToLeft">
                                        <TextBlock Text="فلترة البحث المتقدم" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" HorizontalAlignment="Right" Margin="0,0,0,15"/>
                                        
                                        <!-- Gender Filter -->
                                        <TextBlock Text="الجنس" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                        <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" SelectedValuePath="Content" SelectedValue="{Binding SearchGender}" Height="36" Margin="0,0,0,12">
                                            <ComboBoxItem Content="الكل"/>
                                            <ComboBoxItem Content="ذكر"/>
                                            <ComboBoxItem Content="أنثى"/>
                                        </ComboBox>

                                        <!-- Age Range Filter -->
                                        <TextBlock Text="العمر" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBox Grid.Column="0" Text="{Binding SearchMinAge}" PlaceholderText="الأدنى" HorizontalContentAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="-" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{DynamicResource SubtextColor}"/>
                                            <ui:TextBox Grid.Column="2" Text="{Binding SearchMaxAge}" PlaceholderText="الأقصى" HorizontalContentAlignment="Center"/>
                                        </Grid>

                                        <!-- Governorate Filter -->
                                        <TextBlock Text="المحافظة" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                        <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" SelectedValuePath="Content" SelectedValue="{Binding SearchGovernorate}" Height="36" Margin="0,0,0,12">
                                            <ComboBoxItem Content="الكل"/>
                                            <ComboBoxItem Content="بغداد"/>
                                            <ComboBoxItem Content="البصرة"/>
                                            <ComboBoxItem Content="نينوى"/>
                                            <ComboBoxItem Content="اربيل"/>
                                            <ComboBoxItem Content="النجف"/>
                                            <ComboBoxItem Content="كربلاء"/>
                                            <ComboBoxItem Content="بابل"/>
                                            <ComboBoxItem Content="الأنبار"/>
                                            <ComboBoxItem Content="ديالى"/>
                                            <ComboBoxItem Content="كركوك"/>
                                            <ComboBoxItem Content="صلاح الدين"/>
                                            <ComboBoxItem Content="السليمانية"/>
                                            <ComboBoxItem Content="دهوك"/>
                                            <ComboBoxItem Content="واسط"/>
                                            <ComboBoxItem Content="ميسان"/>
                                            <ComboBoxItem Content="ذي قار"/>
                                            <ComboBoxItem Content="المثنى"/>
                                            <ComboBoxItem Content="القادسية"/>
                                        </ComboBox>

                                        <!-- Visit Date Range -->
                                        <TextBlock Text="تاريخ الزيارة" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                        <DatePicker Style="{StaticResource MaterialDesignOutlinedDatePicker}" SelectedDate="{Binding SearchStartDate}" materialDesign:HintAssist.Hint="من تاريخ" Height="36" Margin="0,0,0,8"/>
                                        <DatePicker Style="{StaticResource MaterialDesignOutlinedDatePicker}" SelectedDate="{Binding SearchEndDate}" materialDesign:HintAssist.Hint="إلى تاريخ" Height="36" Margin="0,0,0,12"/>

                                        <Separator Margin="0,5,0,12" Background="{DynamicResource BorderColor}"/>

                                        <!-- Sort options -->
                                        <TextBlock Text="ترتيب حسب" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                        <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" SelectedValuePath="Tag" SelectedValue="{Binding SearchSortField}" Height="36" Margin="0,0,0,8">
                                            <ComboBoxItem Content="الاسم" Tag="Name"/>
                                            <ComboBoxItem Content="العمر" Tag="Age"/>
                                            <ComboBoxItem Content="تاريخ التسجيل" Tag="RegistrationDate"/>
                                            <ComboBoxItem Content="تاريخ آخر زيارة" Tag="LastVisitDate"/>
                                        </ComboBox>
                                        <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" SelectedValuePath="Tag" SelectedValue="{Binding SearchSortDescending}" Height="36" Margin="0,0,0,15">
                                            <ComboBoxItem Content="تصاعدي" Tag="False"/>
                                            <ComboBoxItem Content="تنازلي" Tag="True"/>
                                        </ComboBox>

                                        <!-- Action Buttons -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="تطبيق" Command="{Binding SearchCommand}" Style="{StaticResource ModernButton}" Height="32" Margin="0,0,5,0"/>
                                            <Button Grid.Column="1" Content="إعادة تعيين" Command="{Binding ResetFiltersCommand}" Style="{StaticResource SecondaryButton}" Height="32" Margin="5,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <!-- Patient DataGrid (Column 1) -->
                            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <DataGrid ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatient}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0" Background="Transparent">
                                <DataGrid.Columns>
                                    <!-- Patient Code -->
                                    <DataGridTextColumn Header="الرمز" Binding="{Binding PatientId}" Width="60" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowPatientId, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    
                                    <!-- Patient Name -->
                                    <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="150" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowName, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Age -->
                                    <DataGridTextColumn Header="العمر" Binding="{Binding Age}" Width="60" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowAge, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Gender -->
                                    <DataGridTextColumn Header="الجنس" Binding="{Binding Gender}" Width="70" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowGender, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Governorate -->
                                    <DataGridTextColumn Header="المحافظة" Binding="{Binding Governorate}" Width="90" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowGovernorate, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Phone -->
                                    <DataGridTextColumn Header="رقم الهاتف" Binding="{Binding Phone}" Width="110" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowPhone, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Job -->
                                    <DataGridTextColumn Header="العمل" Binding="{Binding Job}" Width="90" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowJob, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Address -->
                                    <DataGridTextColumn Header="العنوان" Binding="{Binding Address}" Width="150" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowAddress, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Weight -->
                                    <DataGridTextColumn Header="الوزن" Binding="{Binding Weight}" Width="60" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowWeight, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Height -->
                                    <DataGridTextColumn Header="الطول" Binding="{Binding Height}" Width="60" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowHeight, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Marital Status -->
                                    <DataGridTextColumn Header="الحالة الزوجية" Binding="{Binding MaritalStatus}" Width="90" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowMaritalStatus, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Spouse Name -->
                                    <DataGridTextColumn Header="اسم الزوج/ة" Binding="{Binding SpouseName}" Width="100" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowSpouseName, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Blood Group -->
                                    <DataGridTextColumn Header="فصيلة الدم" Binding="{Binding BloodGroup}" Width="80" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowBloodGroup, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Smoking -->
                                    <DataGridTextColumn Header="التدخين" Binding="{Binding Smoking}" Width="70" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowSmoking, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Last Child Birth Date -->
                                    <DataGridTextColumn Header="تاريخ ولادة اخر طفل" Binding="{Binding LastChildBirthDate, StringFormat=\{0:dd/MM/yyyy\}}" Width="120" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowLastChildBirthDate, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Alcohol -->
                                    <DataGridTextColumn Header="الكحول" Binding="{Binding Alcohol}" Width="70" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowAlcohol, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Marriage Date -->
                                    <DataGridTextColumn Header="تاريخ الزواج" Binding="{Binding MarriageDate, StringFormat=\{0:dd/MM/yyyy\}}" Width="100" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowMarriageDate, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Referred By -->
                                    <DataGridTextColumn Header="من طرف" Binding="{Binding ReferredBy}" Width="100" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowReferredBy, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Return Date -->
                                    <DataGridTextColumn Header="تاريخ المراجعة" Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy\}}" Width="100" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowReturnDate, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Last Visit -->
                                    <DataGridTextColumn Header="اخر زيارة" Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy\}}" Width="100" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowLastVisit, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Spouse Birth Date -->
                                    <DataGridTextColumn Header="تاريخ ولادة الزوج/ة" Binding="{Binding SpouseBirthDate, StringFormat=\{0:dd/MM/yyyy\}}" Width="120" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowSpouseBirthDate, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Spouse Blood Group -->
                                    <DataGridTextColumn Header="فصيلة دم الزوج/ة" Binding="{Binding SpouseBloodGroup}" Width="120" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowSpouseBloodGroup, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Has Children -->
                                    <DataGridTextColumn Header="هل يوجد اطفال" Binding="{Binding HasChildren}" Width="100" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowHasChildren, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Visits Count -->
                                    <DataGridTextColumn Header="عدد الزيارات" Binding="{Binding Visits.Count}" Width="90" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowVisitsCount, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Notes -->
                                    <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="150" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowNotes, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Allergy -->
                                    <DataGridTextColumn Header="الحساسية" Binding="{Binding Allergy}" Width="150" IsReadOnly="True"
                                                        Visibility="{Binding Data.ShowAllergy, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Actions dots column -->
                                    <DataGridTemplateColumn Header="الخيارات" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Tag="&#xE712;" Width="28" Height="28" Padding="0" HorizontalAlignment="Center">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="إرسال إلى الطبيب" Command="{Binding Data.SendToQueueCommand, Source={StaticResource Proxy}}" CommandParameter="{Binding}"/>
                                                            <MenuItem Header="تعديل الملف الشخصي" Command="{Binding Data.LoadExistingPatientCommand, Source={StaticResource Proxy}}" CommandParameter="{Binding}"/>
                                                            <Separator/>
                                                            <MenuItem Header="حذف المريض وكافة زياراته" Command="{Binding Data.DeletePatientCommand, Source={StaticResource Proxy}}" CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                                            <EventSetter Event="Click" Handler="GearButton_Click"/>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                        <!-- Panel 2: Today's Visits -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveSubView}" Value="TodayVisits">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="زيارات اليوم" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,15" HorizontalAlignment="Right"/>
                            
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <DataGrid ItemsSource="{Binding TodayVisitsList}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0" Background="Transparent">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="الوقت" Binding="{Binding VisitDate, StringFormat=\{0:hh:mm tt\}}" Width="100" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="رمز المريض" Binding="{Binding PatientId}" Width="100" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="اسم المريض" Binding="{Binding Patient.Name}" Width="250" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTemplateColumn Header="نوع الزيارة" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#EF4444"/> <!-- Red for free -->
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                                        <Setter Property="Background" Value="#10B981"/> <!-- Green for paid -->
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="White">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="مراجعة مجانية"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                                            <Setter Property="Text" Value="زيارة مدفوعة"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="السعر" Binding="{Binding VisitPrice, StringFormat=\{0:N0\} د.ع}" Width="150" IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Grid>

                        <!-- Panel 3: Appointments Calendar -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveSubView}" Value="AppointmentsCalendar">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="مواعيد المراجعات القادمة" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,15" HorizontalAlignment="Right"/>
                            
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <DataGrid ItemsSource="{Binding UpcomingAppointmentsList}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0" Background="Transparent">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="رمز المريض" Binding="{Binding PatientId}" Width="100" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="اسم المريض" Binding="{Binding Patient.Name}" Width="250" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="رقم الهاتف" Binding="{Binding Patient.Phone}" Width="180" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="تاريخ المراجعة" Binding="{Binding ReturnDate, StringFormat=\{0:yyyy/MM/dd\}}" Width="180" IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Grid>

                        <!-- Panel 4: Finance -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveSubView}" Value="Finance">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="التقرير المالي اليومي" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,15" HorizontalAlignment="Right"/>
                            
                            <!-- Stats Cards Grid -->
                            <Grid Grid.Row="1" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Revenue -->
                                <Border Grid.Column="2" Background="#10B981" CornerRadius="8" Padding="15" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="مجموع الإيرادات" FontSize="12" FontWeight="Bold" Foreground="White" TextAlignment="Right"/>
                                        <TextBlock Text="{Binding TotalRevenue, StringFormat=\{0:N0\} د.ع}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,10,0,0" TextAlignment="Right"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Paid Count -->
                                <Border Grid.Column="1" Background="#3B82F6" CornerRadius="8" Padding="15" Margin="8,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="الزيارات المدفوعة" FontSize="12" FontWeight="Bold" Foreground="White" TextAlignment="Right"/>
                                        <TextBlock Text="{Binding PaidVisitsCount}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,10,0,0" TextAlignment="Right"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Free Count -->
                                <Border Grid.Column="0" Background="#EF4444" CornerRadius="8" Padding="15" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="المراجعات المجانية" FontSize="12" FontWeight="Bold" Foreground="White" TextAlignment="Right"/>
                                        <TextBlock Text="{Binding FreeVisitsCount}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,10,0,0" TextAlignment="Right"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            
                            <!-- Finance Table -->
                            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <DataGrid ItemsSource="{Binding TodayVisitsList}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0" Background="Transparent">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="الوقت" Binding="{Binding VisitDate, StringFormat=\{0:hh:mm tt\}}" Width="100" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="اسم المريض" Binding="{Binding Patient.Name}" Width="250" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="نوع الزيارة" Width="150" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="مراجعة مجانية"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                            <Setter Property="Text" Value="زيارة مدفوعة"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="المبلغ المستلم" Binding="{Binding VisitPrice, StringFormat=\{0:N0\} د.ع}" Width="150" IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>
                </Grid>

                <!-- Row 1: Bottom Floating Responsive Bar -->
                <Border Grid.Row="1" CornerRadius="28" Height="56" Margin="0,15,0,5" MaxWidth="760" HorizontalAlignment="Center" Padding="30,0" BorderThickness="1.5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{DynamicResource SecondaryColorVal}" Offset="0"/>
                            <GradientStop Color="{DynamicResource PrimaryColorVal}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="White" Opacity="0.15"/>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#0F172A" Opacity="0.15" BlurRadius="25" ShadowDepth="4" Direction="270"/>
                    </Border.Effect>
                    <Border.Resources>
                        <!-- Special implicit style for buttons inside this toolbar -->
                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Width" Value="44"/>
                            <Setter Property="Height" Value="44"/>
                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.85"/>
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1.15" ScaleY="1.15"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Resources>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Tag="&#xE8A5;" ToolTip="Dashboard | الرئيسية" FontSize="20"
                                Command="{Binding ShowDashboardViewCommand}"/>
                        <Button Grid.Column="1" Tag="&#xE77B;" ToolTip="Patients | المرضى" FontSize="20"
                                Command="{Binding ShowAllPatientsViewCommand}"/>
                        <Button Grid.Column="2" Tag="&#xE81C;" ToolTip="Visits History | السجل اليومي" FontSize="20"
                                Command="{Binding ShowTodayVisitsViewCommand}"/>
                        <Button Grid.Column="3" Tag="&#xE710;" ToolTip="Add Patient | إضافة مريض" FontSize="24" FontWeight="Bold"
                                Command="{Binding OpenRegistrationModalCommand}"/>
                        <Button Grid.Column="4" Tag="&#xE787;" ToolTip="Calendar | التقويم" FontSize="20"
                                Command="{Binding ShowAppointmentsCalendarViewCommand}"/>
                        <Button Grid.Column="5" Tag="&#xE8C7;" ToolTip="Finance | الحسابات" FontSize="20"
                                Command="{Binding ShowFinanceViewCommand}"/>
                        <Button Grid.Column="6" Tag="&#xE713;" ToolTip="Settings | الإعدادات" FontSize="20"
                                Command="{Binding DataContext.NavigateToPrintSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Button Grid.Column="7" Tag="&#xE72B;" ToolTip="Exit | خروج" FontSize="20"
                                Command="{Binding DataContext.NavigateToHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Overlay Modal Dialog: Register / Edit Patient -->
        <Grid Background="#80000000" Visibility="{Binding ShowRegistrationModal, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="12" Width="720" MaxHeight="620" Margin="0,30" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25" FlowDirection="RightToLeft">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.3" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header with gear -->
                        <RowDefinition Height="*"/>    <!-- Scrollable 2 Column form fields -->
                        <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                    </Grid.RowDefinitions>

                    <!-- Modal Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>    <!-- Title -->
                            <ColumnDefinition Width="Auto"/> <!-- Settings Gear -->
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="اضافة المريض" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center"/>
                        
                        <!-- Settings Gear on the Left -->
                        <Grid Grid.Column="1">
                            <Button Style="{StaticResource NavButton}" Content="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource SubtextColor}" Command="{Binding ToggleGearMenuCommand}"/>
                            
                            <!-- 2-Column Popup switches list matching mockup -->
                            <Popup IsOpen="{Binding IsGearMenuOpen, Mode=TwoWay}" StaysOpen="False" Placement="Bottom">
                                <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="8" Padding="15" Width="460">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.15" ShadowDepth="3"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="إعدادات الحقول (عرض / إخفاء)" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,10" HorizontalAlignment="Right"/>
                                        
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Left Column switches (Column 0) -->
                                            <StackPanel Grid.Column="0" Margin="0,0,10,0" FlowDirection="RightToLeft">
                                                <CheckBox Content="العمل" IsChecked="{Binding ShowJob}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="العنوان" IsChecked="{Binding ShowAddress}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="من طرف" IsChecked="{Binding ShowReferredBy}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="الطول" IsChecked="{Binding ShowHeight}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="تاريخ المراجعة" IsChecked="{Binding ShowReturnDate}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="اخر زيارة" IsChecked="{Binding ShowLastVisit}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="تاريخ ولادة الزوج/ة" IsChecked="{Binding ShowSpouseBirthDate}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="فصيلة دم الزوج/ة" IsChecked="{Binding ShowSpouseBloodGroup}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="هل يوجد اطفال" IsChecked="{Binding ShowHasChildren}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="ملاحظات" IsChecked="{Binding ShowNotes}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="الحساسية" IsChecked="{Binding ShowAllergy}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                            </StackPanel>

                                            <!-- Right Column switches (Column 1) -->
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" FlowDirection="RightToLeft">
                                                <CheckBox Content="المحافظة" IsChecked="{Binding ShowGovernorate}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="رقم الهاتف" IsChecked="{Binding ShowPhone}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="الوزن" IsChecked="{Binding ShowWeight}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="الحالة الزوجية" IsChecked="{Binding ShowMaritalStatus}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="عدد الزيارات" IsChecked="{Binding ShowVisitsCount}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="اسم الزوج/ة" IsChecked="{Binding ShowSpouseName}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="فصيلة الدم" IsChecked="{Binding ShowBloodGroup}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="التدخين" IsChecked="{Binding ShowSmoking}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="تاريخ ولادة اخر طفل" IsChecked="{Binding ShowLastChildBirthDate}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="الكحول" IsChecked="{Binding ShowAlcohol}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                                <CheckBox Content="تاريخ الزواج" IsChecked="{Binding ShowMarriageDate}" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Save Button -->
                                        <Button Grid.Row="2" Style="{StaticResource ModernButton}" Content="حفظ كافتراضي" Command="{Binding SavePreferencesCommand}" HorizontalAlignment="Center" Margin="0,15,0,0" Padding="30,6" Height="32" FontSize="12"/>
                                    </Grid>
                                </Border>
                            </Popup>
                        </Grid>
                    </Grid>

                    <!-- Scrollable 2 Column form fields -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                        <Grid Margin="0,0,10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/> <!-- Left Column -->
                                <ColumnDefinition Width="*"/> <!-- Right Column -->
                            </Grid.ColumnDefinitions>

                            <!-- Primary Column (Column 0 - Right side in RTL) -->
                            <StackPanel Grid.Column="0" Margin="10,0,0,0">
                                <!-- Sequence -->
                                <TextBlock Text="تسلسل" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <ui:TextBox Text="{Binding ActiveEditingPatient.PatientId, TargetNullValue='جديد'}" IsReadOnly="True" Background="{DynamicResource BackgroundColor}" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>

                                <!-- Name -->
                                <TextBlock Text="الاسم *" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <ui:TextBox x:Name="RegNameTextBox" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="الاسم" HorizontalContentAlignment="Right"/>
                                    
                                    <!-- Suggestions Popup -->
                                    <Popup IsOpen="{Binding IsSuggestionsOpen, Mode=TwoWay}" StaysOpen="False" PlacementTarget="{Binding ElementName=RegNameTextBox}" Placement="Bottom" Width="{Binding ElementName=RegNameTextBox, Path=ActualWidth}">
                                        <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5" CornerRadius="8" Padding="5" MaxHeight="220">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12" Color="Black" Opacity="0.25" ShadowDepth="4"/>
                                            </Border.Effect>
                                            <ListBox ItemsSource="{Binding NameSuggestions}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                                                Command="{Binding DataContext.SelectNameSuggestionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                CommandParameter="{Binding}"
                                                                HorizontalContentAlignment="Right"
                                                                FlowDirection="RightToLeft"
                                                                Padding="10,6" Height="Auto"
                                                                Margin="0,2">
                                                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{DynamicResource TextColor}" FontSize="12"/>
                                                                <TextBlock Text=" (" Foreground="{DynamicResource SubtextColor}" FontSize="12"/>
                                                                <TextBlock Text="{Binding Age}" Foreground="{DynamicResource SubtextColor}" FontSize="11" VerticalAlignment="Center"/>
                                                                <TextBlock Text=" سنة | yrs)" Foreground="{DynamicResource SubtextColor}" FontSize="11" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <!-- Age in Years -->
                                <TextBlock Text="العمر (سنوات) *" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                <ui:TextBox Text="{Binding Age, Converter={StaticResource ZeroToEmptyConverter}, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="سنوات" Margin="0,0,0,10"/>

                                <!-- Age in Months -->
                                <TextBlock Text="العمر (أشهر)" FontSize="11" Foreground="{StaticResource SubtextColor}" Margin="0,0,0,4"/>
                                <ui:TextBox Text="{Binding AgeMonths, Converter={StaticResource ZeroToEmptyConverter}, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="أشهر" Margin="0,0,0,10"/>

                                <!-- Birth Date -->
                                <TextBlock Text="تاريخ الولادة" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <DatePicker SelectedDate="{Binding BirthDate}" Height="36" Margin="0,0,0,10" FlowDirection="RightToLeft"/>

                                <!-- Phone Number -->
                                <StackPanel Visibility="{Binding ShowPhone, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="رقم الهاتف" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ui:TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="07XX-XXXXXXX" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>
                                </StackPanel>

                                <!-- Job -->
                                <StackPanel Visibility="{Binding ShowJob, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="العمل" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ui:TextBox Text="{Binding Job, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="العمل" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>
                                </StackPanel>

                                <!-- Weight -->
                                <StackPanel Visibility="{Binding ShowWeight, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="الوزن" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ui:TextBox Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="الوزن" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>
                                </StackPanel>

                                <!-- Marital Status -->
                                <StackPanel Visibility="{Binding ShowMaritalStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="الحالة الزوجية" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" SelectedValuePath="Content" SelectedValue="{Binding MaritalStatus, UpdateSourceTrigger=PropertyChanged}" Height="36" Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <ComboBoxItem Content="أعزب"/>
                                        <ComboBoxItem Content="متزوج"/>
                                        <ComboBoxItem Content="مطلق"/>
                                        <ComboBoxItem Content="أرمل"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Spouse Name -->
                                <StackPanel Visibility="{Binding ShowSpouseName, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="اسم الزوج/ة" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ui:TextBox Text="{Binding SpouseName, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="اسم الزوج/ة" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>
                                </StackPanel>

                                <!-- Blood Group -->
                                <StackPanel Visibility="{Binding ShowBloodGroup, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="فصيلة الدم" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" SelectedValuePath="Content" SelectedValue="{Binding BloodGroup, UpdateSourceTrigger=PropertyChanged}" Height="36" Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <ComboBoxItem Content="A+"/>
                                        <ComboBoxItem Content="A-"/>
                                        <ComboBoxItem Content="B+"/>
                                        <ComboBoxItem Content="B-"/>
                                        <ComboBoxItem Content="O+"/>
                                        <ComboBoxItem Content="O-"/>
                                        <ComboBoxItem Content="AB+"/>
                                        <ComboBoxItem Content="AB-"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Smoking -->
                                <StackPanel Visibility="{Binding ShowSmoking, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="التدخين" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" SelectedValuePath="Content" SelectedValue="{Binding Smoking, UpdateSourceTrigger=PropertyChanged}" Height="36" Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <ComboBoxItem Content="مدخن"/>
                                        <ComboBoxItem Content="غير مدخن"/>
                                        <ComboBoxItem Content="مدخن سابق"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Last Child Birth Date -->
                                <StackPanel Visibility="{Binding ShowLastChildBirthDate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="تاريخ ولادة اخر طفل" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <DatePicker SelectedDate="{Binding LastChildBirthDate}" Height="36" Margin="0,0,0,10" FlowDirection="RightToLeft"/>
                                </StackPanel>

                                <!-- Patient Files -->
                                <StackPanel>
                                    <TextBlock Text="الملفات" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:Button Grid.Column="1" Appearance="Secondary" Content="رفع ملف" Command="{Binding UploadPatientFileCommand}" Padding="12,5" FontSize="11" Margin="5,0,0,0"/>
                                        <ui:TextBox Grid.Column="0" Text="{Binding PatientFileName, Mode=OneWay}" IsReadOnly="True" Background="{DynamicResource BackgroundColor}" HorizontalContentAlignment="Right"/>
                                    </Grid>
                                    <!-- File link & Remove -->
                                    <Border Background="{DynamicResource BackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,0,10"
                                            Visibility="{Binding PatientFiles, Converter={StaticResource NullToVisibilityConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,6,0"/>
                                            <Button Grid.Column="1" Content="{Binding PatientFileName}" Style="{StaticResource NavButton}" Padding="0" HorizontalContentAlignment="Left" Foreground="{DynamicResource PrimaryColor}" FontSize="11" FontWeight="SemiBold"
                                                    Command="{Binding OpenPatientFileCommand}" CommandParameter="{Binding PatientFiles}"/>
                                            <Button Grid.Column="2" Style="{StaticResource NavButton}" Width="16" Height="16" Tag="&#xE711;" ToolTip="حذف الملف" Padding="0" Foreground="#EF4444" FontSize="8"
                                                    Command="{Binding RemovePatientFileCommand}"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Secondary Column (Column 1 - Left side in RTL) -->
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <!-- Governorate -->
                                <StackPanel Visibility="{Binding ShowGovernorate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="المحافظة" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" SelectedValuePath="Content" SelectedValue="{Binding Governorate, UpdateSourceTrigger=PropertyChanged}" Height="36" Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <ComboBoxItem Content="بغداد"/>
                                        <ComboBoxItem Content="البصرة"/>
                                        <ComboBoxItem Content="نينوى"/>
                                        <ComboBoxItem Content="اربيل"/>
                                        <ComboBoxItem Content="النجف"/>
                                        <ComboBoxItem Content="كربلاء"/>
                                        <ComboBoxItem Content="بابل"/>
                                        <ComboBoxItem Content="الأنبار"/>
                                        <ComboBoxItem Content="ديالى"/>
                                        <ComboBoxItem Content="كركوك"/>
                                        <ComboBoxItem Content="صلاح الدين"/>
                                        <ComboBoxItem Content="السليمانية"/>
                                        <ComboBoxItem Content="دهوك"/>
                                        <ComboBoxItem Content="واسط"/>
                                        <ComboBoxItem Content="ميسان"/>
                                        <ComboBoxItem Content="ذي قار"/>
                                        <ComboBoxItem Content="المثنى"/>
                                        <ComboBoxItem Content="القادسية"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Address -->
                                <StackPanel Visibility="{Binding ShowAddress, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="العنوان" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ui:TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="العنوان بالتفصيل" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>
                                </StackPanel>

                                <!-- Gender -->
                                <TextBlock Text="الجنس *" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" SelectedValuePath="Content" SelectedValue="{Binding Gender, UpdateSourceTrigger=PropertyChanged}" Height="36" Margin="0,0,0,10" FlowDirection="RightToLeft">
                                    <ComboBoxItem Content="ذكر"/>
                                    <ComboBoxItem Content="أنثى"/>
                                </ComboBox>

                                <!-- Referred By -->
                                <StackPanel Visibility="{Binding ShowReferredBy, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="من طرف" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ui:TextBox Text="{Binding ReferredBy, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="من طرف" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>
                                </StackPanel>

                                <!-- Height -->
                                <StackPanel Visibility="{Binding ShowHeight, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="الطول" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ui:TextBox Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="الطول" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>
                                </StackPanel>

                                <!-- Alcohol -->
                                <StackPanel Visibility="{Binding ShowAlcohol, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="الكحول" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ComboBox SelectedValuePath="Content" SelectedValue="{Binding Alcohol, UpdateSourceTrigger=PropertyChanged}" Height="36" Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <ComboBoxItem Content="نعم"/>
                                        <ComboBoxItem Content="لا"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Marriage Date -->
                                <StackPanel Visibility="{Binding ShowMarriageDate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="تاريخ الزواج" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <DatePicker SelectedDate="{Binding MarriageDate}" Height="36" Margin="0,0,0,10" FlowDirection="RightToLeft"/>
                                </StackPanel>

                                <!-- Spouse Birth Date -->
                                <StackPanel Visibility="{Binding ShowSpouseBirthDate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="تاريخ ولادة الزوج\ة" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <DatePicker SelectedDate="{Binding SpouseBirthDate}" Height="36" Margin="0,0,0,10" FlowDirection="RightToLeft"/>
                                </StackPanel>

                                <!-- Spouse Blood Group -->
                                <StackPanel Visibility="{Binding ShowSpouseBloodGroup, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="فصيلة دم الزوج/ة" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ComboBox SelectedValuePath="Content" SelectedValue="{Binding SpouseBloodGroup, UpdateSourceTrigger=PropertyChanged}" Height="36" Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <ComboBoxItem Content="A+"/>
                                        <ComboBoxItem Content="A-"/>
                                        <ComboBoxItem Content="B+"/>
                                        <ComboBoxItem Content="B-"/>
                                        <ComboBoxItem Content="O+"/>
                                        <ComboBoxItem Content="O-"/>
                                        <ComboBoxItem Content="AB+"/>
                                        <ComboBoxItem Content="AB-"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Has Children -->
                                <StackPanel Visibility="{Binding ShowHasChildren, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="هل يوجد اطفال" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ComboBox SelectedValuePath="Content" SelectedValue="{Binding HasChildren, UpdateSourceTrigger=PropertyChanged}" Height="36" Margin="0,0,0,10" FlowDirection="RightToLeft">
                                        <ComboBoxItem Content="نعم"/>
                                        <ComboBoxItem Content="لا"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Notes -->
                                <StackPanel Visibility="{Binding ShowNotes, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="ملاحظات" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ui:TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="ملاحظات..." Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>
                                </StackPanel>

                                <!-- Allergy -->
                                <StackPanel Visibility="{Binding ShowAllergy, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="الحساسية" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <ui:TextBox Text="{Binding Allergy, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="حساسية المريض من الأدوية أو الأطعمة..." Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <!-- Save & Cancel Buttons -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Appearance="Secondary" Content="إلغاء" Command="{Binding CancelEditCommand}" Height="36" Margin="0,0,5,0" Click="CancelButton_Click" HorizontalAlignment="Stretch"/>
                        <ui:Button Grid.Column="1" Appearance="Primary" Content="حفظ" Command="{Binding RegisterCommand}" Height="36" Margin="5,0,0,0" HorizontalAlignment="Stretch"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Overlay Modal Dialog: Visit Check-in -->
        <Grid Background="#80000000" Visibility="{Binding ShowCheckInModal, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="12" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.3" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- Options -->
                        <RowDefinition Height="Auto"/> <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Text="تسجيل زيارة جديدة للمريض" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right" Margin="0,0,0,20"/>

                    <!-- Options -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <!-- Patient name display -->
                        <TextBlock Text="اسم المريض" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding PendingCheckInPatient.Name}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Right" Margin="0,0,0,15"/>

                        <!-- Visit type choice -->
                        <TextBlock Text="نوع الزيارة" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,15" FlowDirection="RightToLeft">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Paid Visit -->
                            <RadioButton Grid.Column="0" Content="زيارة مدفوعة" IsChecked="{Binding IsPaidVisit}" GroupName="VisitType" HorizontalAlignment="Left"/>
                            <!-- Free Follow-up -->
                            <RadioButton Grid.Column="1" Content="مراجعة مجانية" IsChecked="{Binding IsFreeVisit}" GroupName="VisitType" HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- Price input (only enabled/visible if paid) -->
                        <StackPanel Visibility="{Binding IsPaidVisit, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="سعر الزيارة" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                            <ui:TextBox Text="{Binding VisitPrice, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="25000" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>
                        </StackPanel>

                        <!-- Doctor Selector -->
                        <TextBlock Text="الطبيب المعالج (Select Doctor) *" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  ItemsSource="{Binding Doctors}"
                                  SelectedItem="{Binding SelectedDoctor, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  Height="36" Margin="0,0,0,15" FlowDirection="RightToLeft"/>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Appearance="Secondary" Content="إلغاء" Command="{Binding CancelCheckInCommand}" Height="36" Margin="0,0,5,0" HorizontalAlignment="Stretch"/>
                        <ui:Button Grid.Column="1" Appearance="Primary" Content="تأكيد وتسجيل الدخول" Command="{Binding ConfirmCheckInCommand}" Height="36" Margin="5,0,0,0" HorizontalAlignment="Stretch"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Overlay Modal Dialog: Admin Password Verification -->
        <Grid Background="#80000000" Visibility="{Binding ShowAdminPasswordModal, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="12" Width="380" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.3" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- Input -->
                        <RowDefinition Height="Auto"/> <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="التحقق من صلاحية المشرف (Admin Verification)" FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right" Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <TextBlock Text="أدخل رمز التحقق للمشرف" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <!-- Password Box attempt -->
                        <PasswordBox Style="{StaticResource ModernPasswordBox}" helpers:PasswordHelper.Attach="True" helpers:PasswordHelper.Password="{Binding AdminPasswordAttempt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" FlowDirection="RightToLeft"/>
                        <TextBlock Text="{Binding DoctorValidationErrorMessage}" Foreground="#EF4444" FontSize="11" TextAlignment="Right"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Appearance="Secondary" Content="إلغاء" Command="{Binding CloseDoctorsModalCommand}" Height="36" Margin="0,0,5,0" HorizontalAlignment="Stretch"/>
                        <ui:Button Grid.Column="1" Appearance="Primary" Content="تحقق" Command="{Binding ConfirmAdminPasswordCommand}" Height="36" Margin="5,0,0,0" HorizontalAlignment="Stretch"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Overlay Modal Dialog: Manage Doctors -->
        <Grid Background="#80000000" Visibility="{Binding ShowDoctorsModal, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="12" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.3" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Doctor Add Form -->
                        <RowDefinition Height="*"/>    <!-- Doctors List -->
                        <RowDefinition Height="Auto"/> <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Text="إدارة الأطباء (Manage Doctors)" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right" Margin="0,0,0,20"/>

                    <!-- Form -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <TextBlock Text="اسم الطبيب الجديد" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding NewDoctorName, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="مثال: د. يوسف" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>

                        <TextBlock Text="الاختصاص" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <ui:TextBox Text="{Binding NewDoctorSpecialty, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="مثال: طب عام" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>

                        <TextBlock Text="كلمة المرور (Password)" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <PasswordBox Style="{StaticResource ModernPasswordBox}" helpers:PasswordHelper.Attach="True" helpers:PasswordHelper.Password="{Binding NewDoctorPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" FlowDirection="RightToLeft"/>

                        <ui:Button Appearance="Primary" Content="إضافة طبيب" Command="{Binding AddDoctorCommand}" Height="36" HorizontalAlignment="Right" Width="120" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="{Binding DoctorValidationErrorMessage}" FontSize="11" Foreground="{StaticResource PrimaryColor}" TextAlignment="Right" Margin="0,0,0,10"/>
                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0.5" Height="1" Margin="0,5,0,15"/>
                    </StackPanel>

                    <!-- List of Registered Doctors -->
                    <Grid Grid.Row="2" MaxHeight="160" Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="الأطباء المسجلون حالياً" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Right" Margin="0,0,0,8"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ListBox ItemsSource="{Binding Doctors}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="6,8" FlowDirection="RightToLeft">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextColor}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Specialty}" Foreground="{DynamicResource SubtextColor}" FontSize="11" Margin="15,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>

                    <!-- Close Button -->
                    <ui:Button Grid.Row="3" Appearance="Secondary" Content="إغلاق" Command="{Binding CloseDoctorsModalCommand}" Height="36" HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
