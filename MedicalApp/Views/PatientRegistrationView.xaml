<UserControl x:Class="MedicalApp.Views.PatientRegistrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:MedicalApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="Transparent">
    
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="0">
        <!-- Main Grid Layout (Left Sidebar + Main Area) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/> <!-- Left Sidebar: Queue / Waitlist -->
                <ColumnDefinition Width="*"/>   <!-- Right Content: Stats & Table -->
            </Grid.ColumnDefinitions>

            <!-- Column 0: Left Sidebar (Arabic Titles waitlist) -->
            <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1.5,0">
                <Grid Margin="10,15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Title Header -->
                        <RowDefinition Height="*"/>    <!-- Scrollable Queue list -->
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15" HorizontalAlignment="Right">
                        <TextBlock Text="الزيارات المنتظرة" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextColor}" TextAlignment="Right"/>
                        <TextBlock Text="الزيارات الغير منتهية" FontSize="13" Foreground="{StaticResource SubtextColor}" Margin="0,2,0,0" TextAlignment="Right"/>
                    </StackPanel>

                    <!-- Waitlist Queue List -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding WaitingVisits}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,8" Background="White">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Time -->
                                            <ColumnDefinition Width="*"/>    <!-- Name -->
                                            <ColumnDefinition Width="Auto"/> <!-- Status / Document Icon -->
                                            <ColumnDefinition Width="Auto"/> <!-- badges -->
                                        </Grid.ColumnDefinitions>

                                        <!-- Time (e.g. 07:41) -->
                                        <TextBlock Grid.Column="0" Text="{Binding CreatedAt, StringFormat=\{0:hh:mm tt\}}" FontSize="11" Foreground="#0284C7" VerticalAlignment="Center"/>

                                        <!-- Name in Green -->
                                        <TextBlock Grid.Column="1" Text="{Binding PatientName}" FontSize="12" FontWeight="SemiBold" Foreground="#10B981" Margin="8,0" TextWrapping="Wrap" VerticalAlignment="Center" TextAlignment="Right"/>

                                        <!-- Green Document Icon -->
                                        <TextBlock Grid.Column="2" Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#10B981" Margin="0,0,8,0" VerticalAlignment="Center"/>

                                        <!-- Badges (VS BT) -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Background="#F1F5F9" CornerRadius="3" Padding="4,2" Margin="0,0,4,0">
                                                <TextBlock Text="VS" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SubtextColor}"/>
                                            </Border>
                                            <Border Background="#F1F5F9" CornerRadius="3" Padding="4,2">
                                                <TextBlock Text="BT" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SubtextColor}"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Column 1: Main Area (Stats cards + Patients DataGrid + Bottom Floating Bar) -->
            <Grid Grid.Column="1" Margin="15,15,15,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Stats row -->
                    <RowDefinition Height="*"/>    <!-- Table Grid row -->
                    <RowDefinition Height="Auto"/> <!-- Bottom bar row -->
                </Grid.RowDefinitions>

                <!-- Row 0: Statistics blue cards (RTL layout order) -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card 0: Waiting Patients (المرضى المنتظرون) -->
                    <Border Grid.Column="3" Background="#1E88E5" CornerRadius="6" Padding="15" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="المرضى المنتظرون" FontSize="14" FontWeight="Bold" Foreground="White" TextAlignment="Right"/>
                            <TextBlock Text="{Binding WaitingPatientsCount}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,10,0,10" TextAlignment="Right"/>
                            <TextBlock Text="تم التحديث الآن" FontSize="11" Foreground="#BBDEFB" TextAlignment="Right"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 1: Attending Patients (المرضى الحاضرون) -->
                    <Border Grid.Column="2" Background="#1E88E5" CornerRadius="6" Padding="15" Margin="8,0,8,0">
                        <StackPanel>
                            <TextBlock Text="المرضى الحاضرون" FontSize="14" FontWeight="Bold" Foreground="White" TextAlignment="Right"/>
                            <TextBlock Text="{Binding AttendingPatientsCount}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,10,0,10" TextAlignment="Right"/>
                            <TextBlock Text="تم التحديث الآن" FontSize="11" Foreground="#BBDEFB" TextAlignment="Right"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 2: New Patients (المرضى الجدد) -->
                    <Border Grid.Column="1" Background="#1E88E5" CornerRadius="6" Padding="15" Margin="8,0,8,0">
                        <StackPanel>
                            <TextBlock Text="المرضى الجدد" FontSize="14" FontWeight="Bold" Foreground="White" TextAlignment="Right"/>
                            <TextBlock Text="{Binding NewPatientsTodayCount}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,10,0,10" TextAlignment="Right"/>
                            <TextBlock Text="تم التحديث الآن" FontSize="11" Foreground="#BBDEFB" TextAlignment="Right"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 3: All Patients (جميع المرضى) -->
                    <Border Grid.Column="0" Background="#1E88E5" CornerRadius="6" Padding="15" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="جميع المرضى" FontSize="14" FontWeight="Bold" Foreground="White" TextAlignment="Right"/>
                            <TextBlock Text="{Binding TotalPatientsCount}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,10,0,10" TextAlignment="Right"/>
                            <TextBlock Text="تم التحديث الآن" FontSize="11" Foreground="#BBDEFB" TextAlignment="Right"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Row 1: Large Patient Lookup DataGrid -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Search bar -->
                            <RowDefinition Height="*"/>    <!-- DataGrid -->
                        </Grid.RowDefinitions>

                        <!-- Search Bar -->
                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource ModernTextBox}" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" Tag="بحث باسم المريض أو رقم الهاتف..." Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="بحث" Command="{Binding SearchCommand}" Padding="20,8"/>
                        </Grid>

                        <!-- DataGrid Table -->
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatient}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0" Background="Transparent">
                            <DataGrid.Columns>
                                <!-- Patient Code -->
                                <DataGridTextColumn Header="الرمز" Binding="{Binding PatientId}" Width="60" IsReadOnly="True"/>
                                
                                <!-- Patient Name -->
                                <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="1.5*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Age -->
                                <DataGridTextColumn Header="العمر" Binding="{Binding Age}" Width="60" IsReadOnly="True"/>

                                <!-- Gender -->
                                <DataGridTextColumn Header="الجنس" Binding="{Binding Gender}" Width="70" IsReadOnly="True"/>

                                <!-- Job -->
                                <DataGridTextColumn Header="العمل" Binding="{Binding Job}" Width="80" IsReadOnly="True"/>

                                <!-- Governorate -->
                                <DataGridTextColumn Header="المحافظة" Binding="{Binding Governorate}" Width="90" IsReadOnly="True"/>

                                <!-- Address -->
                                <DataGridTextColumn Header="العنوان" Binding="{Binding Address}" Width="1.2*" IsReadOnly="True"/>

                                <!-- Phone -->
                                <DataGridTextColumn Header="رقم الهاتف" Binding="{Binding Phone}" Width="110" IsReadOnly="True"/>

                                <!-- Return Date (Placeholder / String format) -->
                                <DataGridTextColumn Header="تاريخ المراجعة" Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy\}}" Width="100" IsReadOnly="True"/>

                                <!-- Actions dots column -->
                                <DataGridTemplateColumn Header="الخيارات" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Tag="&#xE712;" Width="28" Height="28" Padding="0" HorizontalAlignment="Center">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="إرسال إلى الطبيب" Command="{Binding DataContext.SendToQueueCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                        <MenuItem Header="تعديل الملف الشخصي" Command="{Binding DataContext.LoadExistingPatientCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                                        <!-- Normal click opens context menu -->
                                                        <EventSetter Event="Click" Handler="GearButton_Click"/>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Row 2: Bottom Floating Blue Bar -->
                <Border Grid.Row="2" Background="#1E88E5" CornerRadius="20" Height="48" Margin="0,15,0,5" Width="400" HorizontalAlignment="Center" Padding="15,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Navigation actions shortcut -->
                        <Button Grid.Column="0" Content="&#xE8A5;" FontFamily="Segoe MDL2 Assets" ToolTip="الرئيسية" Style="{StaticResource NavButton}" Foreground="White" FontSize="18" Padding="0"
                                Command="{Binding DataContext.NavigateToHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Button Grid.Column="1" Content="&#xE77B;" FontFamily="Segoe MDL2 Assets" ToolTip="المرضى" Style="{StaticResource NavButton}" Foreground="White" FontSize="18" Padding="0"/>
                        <Button Grid.Column="2" Content="&#xE81C;" FontFamily="Segoe MDL2 Assets" ToolTip="السجل" Style="{StaticResource NavButton}" Foreground="White" FontSize="18" Padding="0"/>
                        <Button Grid.Column="3" Content="&#xE710;" FontFamily="Segoe MDL2 Assets" ToolTip="اضافة مريض" Style="{StaticResource NavButton}" Foreground="White" FontSize="20" FontWeight="Bold" Padding="0"
                                Command="{Binding OpenRegistrationModalCommand}"/>
                        <Button Grid.Column="4" Content="&#xE787;" FontFamily="Segoe MDL2 Assets" ToolTip="التقويم" Style="{StaticResource NavButton}" Foreground="White" FontSize="18" Padding="0"/>
                        <Button Grid.Column="5" Content="&#xE8C7;" FontFamily="Segoe MDL2 Assets" ToolTip="الحسابات" Style="{StaticResource NavButton}" Foreground="White" FontSize="18" Padding="0"/>
                        <Button Grid.Column="6" Content="&#xE713;" FontFamily="Segoe MDL2 Assets" ToolTip="الاعدادات" Style="{StaticResource NavButton}" Foreground="White" FontSize="18" Padding="0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Overlay Modal Dialog: Register / Edit Patient (visible when ShowRegistrationModal is true) -->
        <Grid Background="#80000000" Visibility="{Binding ShowRegistrationModal, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="12" Width="450" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.3" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Modal Header -->
                    <TextBlock Text="تسجيل مريض جديد" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right" Margin="0,0,0,15"/>

                    <!-- Full Name -->
                    <TextBlock Text="الاسم الكامل" FontSize="12" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Tag="أدخل الاسم الرباعي للمريض..." Margin="0,0,0,12" HorizontalContentAlignment="Right"/>

                    <!-- Age & Gender -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Age -->
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="العمر" FontSize="12" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Age, UpdateSourceTrigger=PropertyChanged}" Tag="سنة" HorizontalContentAlignment="Right"/>
                        </StackPanel>
                        <!-- Gender -->
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="الجنس" FontSize="12" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                            <ComboBox SelectedValuePath="Content" SelectedValue="{Binding Gender, UpdateSourceTrigger=PropertyChanged}" Height="36">
                                <ComboBoxItem Content="Male"/>
                                <ComboBoxItem Content="Female"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Phone Number -->
                    <TextBlock Text="رقم الهاتف" FontSize="12" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Tag="رقم الموبايل..." Margin="0,0,0,12" HorizontalContentAlignment="Right"/>

                    <!-- Job & Governorate -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Governorate -->
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="المحافظة" FontSize="12" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Governorate, UpdateSourceTrigger=PropertyChanged}" Tag="المحافظة..." HorizontalContentAlignment="Right"/>
                        </StackPanel>
                        <!-- Job -->
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="العمل" FontSize="12" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Job, UpdateSourceTrigger=PropertyChanged}" Tag="المهنة..." HorizontalContentAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <!-- Address -->
                    <TextBlock Text="العنوان بالتفصيل" FontSize="12" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,20" HorizontalContentAlignment="Right"/>

                    <!-- Save & Cancel Action buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource ModernButton}" Content="إلغاء" Command="{Binding CancelEditCommand}" Background="#EF4444" BorderBrush="#EF4444" Height="36" Margin="0,0,5,0" Click="CancelButton_Click"/>
                        <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="حفظ" Command="{Binding RegisterCommand}" Height="36" Margin="5,0,0,0"/>
                    </Grid>

                    <!-- Status / Error Messages inside modal -->
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PrimaryColor}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
