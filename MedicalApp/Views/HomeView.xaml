<UserControl x:Class="MedicalApp.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="Transparent">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Welcome Header -->
            <RowDefinition Height="*"/>    <!-- Cards Grid -->
        </Grid.RowDefinitions>

        <!-- Welcome Banner Header -->
        <Grid Grid.Row="0" Margin="0,30,0,10">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Welcome back, Dr. Yaser" Style="{StaticResource Header1}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Select a clinical room or registry desk below to manage clinic sessions and patient workflow." Style="{StaticResource Subheading}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
            
            <!-- Top Right Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,20,0">
                <!-- Theme Toggle Button -->
                <Button Width="40" Height="40" Padding="0" Margin="0,0,10,0"
                        Command="{Binding ToggleThemeCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                            <Setter Property="Tag" Value="&#xE708;"/> <!-- Moon icon -->
                            <Setter Property="ToolTip" Value="Switch to Dark Mode"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                    <Setter Property="Tag" Value="&#xE706;"/> <!-- Sun icon -->
                                    <Setter Property="ToolTip" Value="Switch to Light Mode"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Settings Button -->
                <Button Style="{StaticResource NavButton}" Padding="10" Width="40" Height="40"
                        Tag="&#xE713;" ToolTip="Print &amp; Calibration Settings"
                        Command="{Binding DataContext.NavigateToPrintSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>
        </Grid>

        <!-- Selection Cards Grid -->
        <Grid Grid.Row="1" MaxWidth="760" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300" MaxWidth="360"/>
                <ColumnDefinition Width="*" MinWidth="300" MaxWidth="360"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Patient Registry -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Icon -->
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="*"/>    <!-- Description -->
                        <RowDefinition Height="Auto"/> <!-- Enter Button -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{DynamicResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,20,0,25"/>
                    <TextBlock Grid.Row="1" Text="Secretary" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextColor}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Grid.Row="2" Text="Enroll new patients, look up existing patient files with autocomplete search-as-you-type, and send patients to today's active waitlist queue." 
                               FontSize="12" Foreground="{DynamicResource SubtextColor}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="18" Margin="0,0,0,25"/>
                    
                    <Button Grid.Row="3" Style="{StaticResource ModernButton}" Content="Enter Secretary Room" Command="{Binding NavigateToRegistryCommand}" Height="40" HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- Card 2: Doctor -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Icon -->
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="*"/>    <!-- Description -->
                        <RowDefinition Height="Auto"/> <!-- Enter Button -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="&#xE1E2;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{DynamicResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,20,0,25"/>
                    <TextBlock Grid.Row="1" Text="Doctor" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextColor}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Grid.Row="2" Text="Manage queued patients in real-time, view full clinical exam timeline logs, write notes, and direct patients to completion." 
                               FontSize="12" Foreground="{DynamicResource SubtextColor}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="18" Margin="0,0,0,25"/>
                    
                    <Button Grid.Row="3" Style="{StaticResource ModernButton}" Content="Enter Doctor Room" Command="{Binding NavigateToExamCommand}" Height="40" HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Overlay Modal Dialog: Doctor Login/Selection -->
        <Grid Grid.RowSpan="2" Background="#80000000" Visibility="{Binding ShowDoctorLoginModal, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="12" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.3" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- Fields -->
                        <RowDefinition Height="Auto"/> <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Text="تسجيل دخول الطبيب (Doctor Room Entry)" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right" Margin="0,0,0,20"/>

                    <!-- Options/Fields -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <!-- Doctor Selection -->
                        <TextBlock Text="اختر الطبيب المعالج (Select Doctor)" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Doctors}"
                                  SelectedItem="{Binding SelectedDoctor, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  Height="36" Margin="0,0,0,15" FlowDirection="RightToLeft"/>

                        <!-- Password input -->
                        <TextBlock Text="كلمة المرور (Password)" FontSize="11" Foreground="{StaticResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding DoctorPasswordAttempt, UpdateSourceTrigger=PropertyChanged}" Tag="كلمة المرور" Margin="0,0,0,10" HorizontalContentAlignment="Right"/>
                        
                        <!-- Error Message -->
                        <TextBlock Text="{Binding LoginErrorMessage}" Foreground="#EF4444" FontSize="11" TextAlignment="Right"/>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource ModernButton}" Content="إلغاء" Command="{Binding CloseDoctorLoginModalCommand}" Background="#EF4444" BorderBrush="#EF4444" Height="36" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="دخول" Command="{Binding ConfirmDoctorLoginCommand}" Height="36" Margin="5,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
