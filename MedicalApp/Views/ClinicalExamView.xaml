<UserControl x:Class="MedicalApp.Views.ClinicalExamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:MedicalApp.Converters"
             xmlns:helpers="clr-namespace:MedicalApp.Helpers"
             xmlns:views="clr-namespace:MedicalApp.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100"
             Background="Transparent">
    
    <UserControl.Resources>
        <views:BindingProxy x:Key="Proxy" Data="{Binding}"/>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <materialDesign:DialogHost Identifier="ExamDialogHost" IsOpen="{Binding IsDialogOpen}" CloseOnClickAway="True">
            <materialDesign:DialogHost.DialogContent>
                <Grid>
                    <!-- Template selection dialog -->
                    <Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="20" Width="360" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                            Visibility="{Binding IsTemplateDialog, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="15"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding DialogHeader}" Style="{StaticResource Header2}" HorizontalAlignment="Right"/>
                            <ListBox Grid.Row="2" ItemsSource="{Binding DialogTemplateItems}" SelectedItem="{Binding SelectedTemplateItem}" Height="180">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource TextColor}" FontSize="12.5" FlowDirection="RightToLeft"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="إلغاء" Style="{StaticResource SecondaryButton}" Command="{Binding CloseDialogCommand}" Margin="0,0,5,0" Height="36"/>
                                <Button Grid.Column="1" Content="إدراج" Style="{StaticResource ModernButton}" Command="{Binding SelectTemplateCommand}" Margin="5,0,0,0" Height="36"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </materialDesign:DialogHost.DialogContent>

            <!-- Main Layout Grid -->
            <Grid>
                <!-- 1. Placeholder when no active patient is selected -->
                <Grid Visibility="{Binding CurrentPatient, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                    <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="16" Width="420" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="No Active Exam Session" Style="{StaticResource Header1}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="To start examining a patient, please select a patient from the waitlist on the Home dashboard portal." FontSize="13" Foreground="{DynamicResource SubtextColor}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,25" LineHeight="18"/>
                            <Button Style="{StaticResource ModernButton}" Content="Go to Home Dashboard" Command="{Binding ExitToDashboardCommand}" Height="40" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 2. Active Exam Session Room Layout (Clinic360 Style) -->
                <Grid Visibility="{Binding CurrentPatient, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Row 0: Top Action Header Bar -->
                        <RowDefinition Height="*"/>    <!-- Row 1: 3-Column Workspace -->
                    </Grid.RowDefinitions>

                    <!-- ROW 0: TOP ACTION HEADER BAR (Clinic360 Style) -->
                    <Border Grid.Row="0" Background="{DynamicResource BottomBarBackground}" Padding="16,10" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Margin="-12,-12,-12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- Back button -->
                                <ColumnDefinition Width="Auto"/> <!-- Patient name + badges -->
                                <ColumnDefinition Width="*"/>    <!-- Status message center -->
                                <ColumnDefinition Width="Auto"/> <!-- Action buttons -->
                            </Grid.ColumnDefinitions>

                            <!-- Back to Dashboard -->
                            <Button Grid.Column="0" Style="{StaticResource IconButton}" Tag="&#xE72B;" ToolTip="Back to Dashboard" Command="{Binding ExitToDashboardCommand}" Foreground="White" FontSize="20" Width="40" Height="40" VerticalAlignment="Center"/>

                            <!-- Patient Name + Badges -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock Text="{Binding CurrentPatient.Name}" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Border Background="{DynamicResource SelectedTabBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentPatient.PatientId, StringFormat='#PAT{0:0000}'}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SelectedTabTextBrush}"/>
                                </Border>
                                <Border Background="{DynamicResource InfoBadgeBackground}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentPatient.Age, StringFormat='Age: {0} yrs'}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource InfoBadgeText}"/>
                                </Border>
                                <Border Background="{DynamicResource InfoBadgeBackground}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentPatient.Gender}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource InfoBadgeText}"/>
                                </Border>
                            </StackPanel>

                            <!-- Center Status -->
                            <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" Foreground="{DynamicResource PrimaryColor}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>

                            <!-- Right Action Buttons -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Saved Badge -->
                                <Border Background="{DynamicResource SuccessBackgroundColor}" CornerRadius="6" Padding="10,4" Margin="0,0,8,0" VerticalAlignment="Center" Visibility="{Binding ShowSavedBadge, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource SuccessColor}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Saved" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SuccessColor}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Section Settings (Configure visible panels) -->
                                <ToggleButton Name="BtnSectionSettings" Style="{StaticResource IconToggleButton}" Tag="&#xE8A4;" ToolTip="Visible Sections | الأقسام الظاهرة" FontSize="17" Width="40" Height="40" Foreground="White" Margin="0,0,10,0"/>
                                <Popup IsOpen="{Binding IsChecked, ElementName=BtnSectionSettings}" PlacementTarget="{Binding ElementName=BtnSectionSettings}" Placement="Bottom" StaysOpen="False" PopupAnimation="Fade">
                                    <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="15" Width="220" Margin="0,5,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Color="Black" Opacity="0.3"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock Text="Visible Sections | الأقسام الظاهرة" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,0,10"/>
                                            <CheckBox Content="Nutritional Status" IsChecked="{Binding ShowNutritionalSub}" Margin="0,0,0,6"/>
                                            <CheckBox Content="Obstetrics / Gynae" IsChecked="{Binding ShowObstetricsSub}" Margin="0,0,0,6"/>
                                            <CheckBox Content="System Review" IsChecked="{Binding ShowSystemReviewSection}" Margin="0,0,0,6"/>
                                            <CheckBox Content="Clinical Examination" IsChecked="{Binding ShowExaminationSection}" Margin="0,0,0,6"/>
                                            <CheckBox Content="Dentist Notes" IsChecked="{Binding DentistShowNotes}" Margin="0,0,0,6"/>
                                            <CheckBox Content="Visit Summary notes" IsChecked="{Binding SummeryShowVisitSummary}" Margin="0,0,0,6"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                <!-- Print & Calibration Settings Gear -->
                                <Button Style="{StaticResource IconButton}" Tag="&#xE713;" ToolTip="Doctor Print &amp; Calibration Settings | إعدادات الطبيب"
                                        Command="{Binding DataContext.NavigateToPrintSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="Doctor" Foreground="White" FontSize="17" Width="40" Height="40" Margin="0,0,10,0"/>

                                <!-- Pause Button -->
                                <Button Style="{StaticResource WarningButton}" Content="⏸ Pause" Command="{Binding HoldSessionCommand}" Height="36" Padding="18,0" Margin="0,0,10,0" FontSize="13"/>
                                <!-- End Button -->
                                <Button Style="{StaticResource DangerButton}" Content="● End" Command="{Binding CompleteSessionDoneCommand}" Height="36" Padding="18,0" FontSize="13"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- ROW 1: 3-COLUMN WORKSPACE -->
                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/> <!-- Col 0: Left Sidebar -->
                            <ColumnDefinition Width="*"/>    <!-- Col 1: Center Workspace -->
                            <ColumnDefinition Width="280"/>  <!-- Col 2: Right Patient Panel -->
                        </Grid.ColumnDefinitions>

                        <!-- COL 0: LEFT SIDEBAR NAVIGATION -->
                        <Border Grid.Column="0" Background="{DynamicResource BottomBarBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0" Padding="0,8" Margin="-12,0,0,0">
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Width" Value="190"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                                <Setter Property="Width" Value="55"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <RadioButton Style="{StaticResource SidebarNavRadioButton}" GroupName="SidebarGroup" Tag="&#xE90B;" Content="Complaints" Click="SidebarNav_Click" CommandParameter="CardComplaints" helpers:BadgeHelper.HasData="{Binding HasChiefComplaint}" IsChecked="True" Margin="0,0,0,2"/>
                                    <RadioButton Style="{StaticResource SidebarNavRadioButton}" GroupName="SidebarGroup" Tag="&#xE95E;" Content="Vital Signs" Click="SidebarNav_Click" CommandParameter="CardVitals" helpers:BadgeHelper.HasData="{Binding HasVitals}" Margin="0,0,0,2"/>
                                    <RadioButton Style="{StaticResource SidebarNavRadioButton}" GroupName="SidebarGroup" Tag="&#xE823;" Content="HPI" Click="SidebarNav_Click" CommandParameter="CardHpi" helpers:BadgeHelper.HasData="{Binding HasHPI}" Margin="0,0,0,2"/>
                                    <RadioButton Style="{StaticResource SidebarNavRadioButton}" GroupName="SidebarGroup" Tag="&#xE97C;" Content="Examination" Click="SidebarNav_Click" CommandParameter="CardExam" helpers:BadgeHelper.HasData="{Binding HasPhysicalExam}" Margin="0,0,0,2"/>
                                    <RadioButton Style="{StaticResource SidebarNavRadioButton}" GroupName="SidebarGroup" Tag="&#xE70F;" Content="Treatment Plan" Click="SidebarNav_Click" CommandParameter="CardPlan" helpers:BadgeHelper.HasData="{Binding HasTreatmentPlan}" Margin="0,0,0,2"/>
                                    <RadioButton Style="{StaticResource SidebarNavRadioButton}" GroupName="SidebarGroup" Tag="&#xE8FB;" Content="Diagnosis" Click="SidebarNav_Click" CommandParameter="CardDx" helpers:BadgeHelper.HasData="{Binding HasDiagnosis}" Margin="0,0,0,2"/>
                                    <RadioButton Style="{StaticResource SidebarNavRadioButton}" GroupName="SidebarGroup" Tag="&#xEA1F;" Content="Prescription" Click="SidebarNav_Click" CommandParameter="CardRx" helpers:BadgeHelper.HasData="{Binding HasPrescription}" Margin="0,0,0,2"/>
                                    <RadioButton Style="{StaticResource SidebarNavRadioButton}" GroupName="SidebarGroup" Tag="&#xF191;" Content="Investigations" Click="SidebarNav_Click" CommandParameter="CardLabs" helpers:BadgeHelper.HasData="{Binding HasInvestigations}" Margin="0,0,0,2"/>
                                    <RadioButton Style="{StaticResource SidebarNavRadioButton}" GroupName="SidebarGroup" Tag="&#xE91B;" Content="Imaging" Click="SidebarNav_Click" CommandParameter="CardImaging" helpers:BadgeHelper.HasData="{Binding HasImaging}" Margin="0,0,0,2"/>
                                    <RadioButton Style="{StaticResource SidebarNavRadioButton}" GroupName="SidebarGroup" Tag="&#xE81C;" Content="Past History" Click="SidebarNav_Click" CommandParameter="CardHistory" helpers:BadgeHelper.HasData="{Binding HasHistory}" Margin="0,0,0,2"/>
                                </StackPanel>
                                <!-- Collapse Toggle -->
                                <Button Grid.Row="1" Command="{Binding ToggleSidebarCommand}" Foreground="{DynamicResource SubtextColor}" FontSize="16" Width="36" Height="36" Margin="0,0,0,8">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                            <Setter Property="Tag" Value="&#xE76B;"/>
                                            <Setter Property="ToolTip" Value="Collapse Sidebar"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                    <Setter Property="Tag" Value="&#xE76C;"/>
                                                    <Setter Property="ToolTip" Value="Expand Sidebar"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                                           <!-- COL 1: CENTER CLINICAL WORKSPACE (Modern Single-Column Dashboard) -->
                        <ScrollViewer x:Name="CenterScrollViewer" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20,0,20,15">
                            <StackPanel Margin="0,0,0,10">
                                
                                <!-- 1. Chief Complaint -->
                                <ui:Card x:Name="CardComplaints" Margin="0,0,0,12" Visibility="{Binding ShowComplaint, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE90B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Complaints | الشكوى الرئيسية" Style="{StaticResource Header2}" Margin="0"/>
                                            </StackPanel>
                                            <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}" Tag="&#xE720;" ToolTip="Voice Input" Command="{Binding SimulateVoiceInputCommand}" CommandParameter="ChiefComplaint"/>
                                        </Grid>
                                        <ui:TextBox Text="{Binding ChiefComplaint, UpdateSourceTrigger=PropertyChanged}" Height="70" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                                        
                                        <!-- Quick Narrative Chips -->
                                        <WrapPanel Margin="0,8,0,0">
                                            <Button Style="{StaticResource ChipButton}" Content="Fever | حرارة" Command="{Binding AppendTextCommand}" CommandParameter="Complaint:Fever / حمى وارتفاع حرارة"/>
                                            <Button Style="{StaticResource ChipButton}" Content="Cough | سعال" Command="{Binding AppendTextCommand}" CommandParameter="Complaint:Dry Cough / سعال جاف"/>
                                            <Button Style="{StaticResource ChipButton}" Content="Headache | صداع" Command="{Binding AppendTextCommand}" CommandParameter="Complaint:Severe Headache / صداع شديد"/>
                                            <Button Style="{StaticResource ChipButton}" Content="Abdominal Pain | ألم بطن" Command="{Binding AppendTextCommand}" CommandParameter="Complaint:Abdominal Pain / ألم في البطن"/>
                                            <Button Style="{StaticResource ChipButton}" Content="Shortness of Breath | ضيق نفس" Command="{Binding AppendTextCommand}" CommandParameter="Complaint:Shortness of breath / ضيق وصعوبة في التنفس"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </ui:Card>

                                <!-- 2. Vital Signs -->
                                <ui:Card x:Name="CardVitals" Margin="0,0,0,12" Visibility="{Binding ShowVitals, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE95E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Vital Signs | العلامات الحيوية" Style="{StaticResource Header2}" Margin="0"/>
                                            </StackPanel>
                                            <CheckBox Content="Stable" IsChecked="{Binding IsVitallyStable}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                        
                                        <!-- Premium 3-Column Metric Cards Grid -->
                                        <UniformGrid Columns="3">
                                            
                                            <!-- SPO2 Card -->
                                            <Border CornerRadius="8" Background="#1E293B" BorderThickness="1.5" Padding="12,10" Margin="0,0,8,10">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="#334155"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSPO2AlertVisible}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{Binding SPO2AlertBackground}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,6">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE95A;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#3B82F6" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBlock Text="SPO2" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                            <TextBlock Text=" (%)" FontSize="11" Foreground="{DynamicResource SubtextColor}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border CornerRadius="6" Background="{Binding SPO2AlertBackground}" Visibility="{Binding IsSPO2AlertVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Padding="6,2" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding SPO2AlertText}" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                    <TextBox Style="{StaticResource CompactVitalInput}" Text="{Binding VitalSPO2, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Temperature Card -->
                                            <Border CornerRadius="8" Background="#1E293B" BorderThickness="1.5" Padding="12,10" Margin="4,0,4,10">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="#334155"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTempAlertVisible}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{Binding TempAlertBackground}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,6">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE9CA;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#EF4444" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBlock Text="Temp" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                            <TextBlock Text=" (°C)" FontSize="11" Foreground="{DynamicResource SubtextColor}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border CornerRadius="6" Background="{Binding TempAlertBackground}" Visibility="{Binding IsTempAlertVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Padding="6,2" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding TempAlertText}" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                    <TextBox Style="{StaticResource CompactVitalInput}" Text="{Binding VitalTemp, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Blood Pressure Card -->
                                            <Border CornerRadius="8" Background="#1E293B" BorderThickness="1.5" Padding="12,10" Margin="8,0,0,10">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="#334155"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBPAlertVisible}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{Binding BPAlertBackground}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,6">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xEC05;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#8B5CF6" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBlock Text="BP" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                            <TextBlock Text=" (mmHg)" FontSize="11" Foreground="{DynamicResource SubtextColor}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border CornerRadius="6" Background="{Binding BPAlertBackground}" Visibility="{Binding IsBPAlertVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Padding="6,2" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding BPAlertText}" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Style="{StaticResource CompactVitalInput}" Text="{Binding VitalSBP, UpdateSourceTrigger=PropertyChanged}" Tag="Sys"/>
                                                        <TextBlock Grid.Column="1" Text="/" Margin="4,0,4,8" VerticalAlignment="Center" Foreground="{DynamicResource SubtextColor}" FontWeight="Bold"/>
                                                        <TextBox Grid.Column="2" Style="{StaticResource CompactVitalInput}" Text="{Binding VitalDBP, UpdateSourceTrigger=PropertyChanged}" Tag="Dia"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <!-- Heart Rate Card -->
                                            <Border CornerRadius="8" Background="#1E293B" BorderThickness="1.5" Padding="12,10" Margin="0,0,8,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="#334155"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHRAlertVisible}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{Binding HRAlertBackground}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,6">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE95E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#EC4899" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBlock Text="Heart Rate" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                            <TextBlock Text=" (bpm)" FontSize="11" Foreground="{DynamicResource SubtextColor}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border CornerRadius="6" Background="{Binding HRAlertBackground}" Visibility="{Binding IsHRAlertVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Padding="6,2" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding HRAlertText}" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                    <TextBox Style="{StaticResource CompactVitalInput}" Text="{Binding VitalHR, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Blood Sugar Card -->
                                            <Border CornerRadius="8" Background="#1E293B" BorderThickness="1.5" Padding="12,10" Margin="4,0,4,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="#334155"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBSAlertVisible}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{Binding BSAlertBackground}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,6">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xEA6C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#10B981" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBlock Text="Blood Sugar" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                            <TextBlock Text=" (mg/dL)" FontSize="11" Foreground="{DynamicResource SubtextColor}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border CornerRadius="6" Background="{Binding BSAlertBackground}" Visibility="{Binding IsBSAlertVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Padding="6,2" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding BSAlertText}" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                    <TextBox Style="{StaticResource CompactVitalInput}" Text="{Binding VitalBS, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Respiratory Rate Card -->
                                            <Border CornerRadius="8" Background="#1E293B" BorderThickness="1.5" Padding="12,10" Margin="8,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="#334155"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRRAlertVisible}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{Binding RRAlertBackground}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,6">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xEC02;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#F59E0B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBlock Text="Resp. Rate" Style="{StaticResource Subheading}" VerticalAlignment="Center"/>
                                                            <TextBlock Text=" (bpm)" FontSize="11" Foreground="{DynamicResource SubtextColor}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border CornerRadius="6" Background="{Binding RRAlertBackground}" Visibility="{Binding IsRRAlertVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Padding="6,2" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding RRAlertText}" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                    <TextBox Style="{StaticResource CompactVitalInput}" Text="{Binding VitalRR, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                </ui:Card>

                                <!-- 3. HPI & Physical Exam -->
                                <ui:Card x:Name="CardHpi" Margin="0,0,0,12" Visibility="{Binding ShowComplaint, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="History of Present Illness (HPI) | القصة المرضية" Style="{StaticResource Header2}" Margin="0"/>
                                            </StackPanel>
                                            <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}" Tag="&#xE720;" Command="{Binding SimulateVoiceInputCommand}" CommandParameter="HPI"/>
                                        </Grid>
                                        <ui:TextBox Text="{Binding HistoryOfPresentIllness, UpdateSourceTrigger=PropertyChanged}" Height="75" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>

                                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                                            <StackPanel x:Name="CardExam">
                                                <Grid Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE97C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Examination | الفحص السريري" Style="{StaticResource Header2}" Margin="0"/>
                                                    </StackPanel>
                                                    <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}" Tag="&#xE720;" Command="{Binding SimulateVoiceInputCommand}" CommandParameter="PhysicalExam"/>
                                                </Grid>
                                                <ui:TextBox Text="{Binding PhysicalExamination, UpdateSourceTrigger=PropertyChanged}" Height="75" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>
                                                
                                                <!-- Quick Narrative Chips for Physical Exam -->
                                                <WrapPanel>
                                                    <Button Style="{StaticResource ChipButton}" Content="Chest Clear | الصدر صافي" Command="{Binding AppendTextCommand}" CommandParameter="Exam:Chest is clear / الصدر صافي بالإصغاء"/>
                                                    <Button Style="{StaticResource ChipButton}" Content="ENT Normal | الحلق طبيعي" Command="{Binding AppendTextCommand}" CommandParameter="Exam:ENT normal / الأنف والأذن والحنجرة طبيعي"/>
                                                    <Button Style="{StaticResource ChipButton}" Content="Abdomen Soft | البطن لين" Command="{Binding AppendTextCommand}" CommandParameter="Exam:Abdomen soft, lax / البطن لين ولا يوجد مضض"/>
                                                    <Button Style="{StaticResource ChipButton}" Content="Stable | حالة مستقرة" Command="{Binding AppendTextCommand}" CommandParameter="Exam:General condition stable / الحالة العامة مستقرة"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ui:Card>

                                <!-- 4. Diagnosis & Return -->
                                <Border x:Name="CardDx" Style="{StaticResource AccentCardBorder}" Margin="0,0,0,12" Visibility="{Binding ShowDiagnosis, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Diagnosis &amp; Return | التشخيص والمراجعة" Style="{StaticResource Header2}"/>
                                        </StackPanel>
                                        <Grid Margin="0,5,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                                <TextBlock Text="Diagnosis Description (Dx)" Style="{StaticResource Subheading}"/>
                                                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Diagnosis, UpdateSourceTrigger=PropertyChanged}" Tag="e.g. Flu, Tonsillitis | اكتب التشخيص الطبي هنا..."/>
                                                
                                                <!-- Quick Narrative Chips -->
                                                <WrapPanel Margin="0,8,0,0">
                                                    <Button Style="{StaticResource ChipButton}" Content="Flu | إنفلونزا" Command="{Binding AppendTextCommand}" CommandParameter="Dx:Common Flu / إنفلونزا ونزلة برد"/>
                                                    <Button Style="{StaticResource ChipButton}" Content="Gastroenteritis | نزلة معوية" Command="{Binding AppendTextCommand}" CommandParameter="Dx:Acute Gastroenteritis / التهاب المعدة والأمعاء الحاد"/>
                                                    <Button Style="{StaticResource ChipButton}" Content="Hypertension | ضغط مرتفع" Command="{Binding AppendTextCommand}" CommandParameter="Dx:Hypertension / ارتفاع ضغط الدم الشرياني"/>
                                                    <Button Style="{StaticResource ChipButton}" Content="Tonsillitis | التهاب اللوزتين" Command="{Binding AppendTextCommand}" CommandParameter="Dx:Acute Tonsillitis / التهاب اللوزتين الحاد"/>
                                                </WrapPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Return Visit Date" Style="{StaticResource Subheading}"/>
                                                <DatePicker SelectedDate="{Binding ReturnDate}" Height="36"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 5. Prescription -->
                                <ui:Card x:Name="CardRx" Margin="0,0,0,12" Visibility="{Binding ShowDrugs, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Prescription | الوصفة الطبية" Style="{StaticResource Header2}" Margin="0"/>
                                            </StackPanel>
                                            <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}" Tag="&#xE720;" Command="{Binding SimulateVoiceInputCommand}" CommandParameter="Prescription"/>
                                        </Grid>
                                        
                                        <!-- Drug Search -->
                                        <Grid Margin="0,0,0,8">
                                            <ui:TextBox x:Name="DrugSearchTextBox" Text="{Binding DrugSearchText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Search medication name..." PreviewKeyDown="DrugSearchTextBox_PreviewKeyDown">
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="Enter" Command="{Binding HandleDrugSearchEnterCommand}"/>
                                                </TextBox.InputBindings>
                                            </ui:TextBox>
                                            <Popup x:Name="DrugSuggestionsPopup" IsOpen="{Binding IsDrugSuggestionsOpen}" Placement="Bottom" StaysOpen="False" Width="280">
                                                <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" MaxHeight="180">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <ListBox x:Name="DrugSuggestionsListBox" ItemsSource="{Binding DrugSuggestions}" SelectedItem="{Binding SelectedSuggestedDrug}" PreviewKeyDown="DrugSuggestionsListBox_PreviewKeyDown">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding}" Foreground="{DynamicResource TextColor}" Padding="5"/>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </ScrollViewer>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                        
                                        <!-- Add Button and Drug Presets -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:Button Grid.Column="0" Appearance="Secondary" Content="Add to Prescription" Command="{Binding AddDrugCommand}" Height="34" Padding="15,0" Margin="0,0,12,0"/>
                                            
                                            <!-- Quick Presets -->
                                            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Style="{StaticResource ChipButton}" Content="Panadol (500mg)" Command="{Binding AddPresetDrugCommand}" CommandParameter="Panadol 500mg|1 tab|Tablet | حبوب|3x Daily | 3 مرات يومياً|After meals"/>
                                                    <Button Style="{StaticResource ChipButton}" Content="Amoxil (500mg)" Command="{Binding AddPresetDrugCommand}" CommandParameter="Amoxil 500mg|1 cap|Capsule | كبسولة|3x Daily | 3 مرات يومياً|For 7 days"/>
                                                    <Button Style="{StaticResource ChipButton}" Content="Brufen (400mg)" Command="{Binding AddPresetDrugCommand}" CommandParameter="Brufen 400mg|1 tab|Tablet | حبوب|2x Daily | مرتين يومياً|After meals"/>
                                                    <Button Style="{StaticResource ChipButton}" Content="Cough Syrup" Command="{Binding AddPresetDrugCommand}" CommandParameter="Cough Syrup|5ml|Syrup | شراب|3x Daily | 3 مرات يومياً|After meals"/>
                                                    <Button Style="{StaticResource ChipButton}" Content="Salbutamol" Command="{Binding AddPresetDrugCommand}" CommandParameter="Salbutamol Inhaler|2 puffs|Inhaler | بخاخ|As needed | عند الحاجة|When short of breath"/>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Grid>

                                        <!-- Prescribed Drugs List (Clinic360 Inline Style) -->
                                        <ItemsControl ItemsSource="{Binding PrescribedDrugs}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1.5" CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            
                                                            <!-- Row 1: Drug Name and Actions -->
                                                            <Grid Grid.Row="0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="&#xE966;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource PrimaryColor}" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13.5" Foreground="{DynamicResource TextColor}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                                
                                                                <Button Grid.Column="1" Style="{StaticResource IconButton}" Tag="&#xE711;" ToolTip="Remove | حذف" Command="{Binding DataContext.RemoveDrugCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Foreground="{DynamicResource AccentColor}" FontSize="15" VerticalAlignment="Center"/>
                                                            </Grid>
                                                            
                                                            <!-- Row 2: Structured & Labeled Inputs -->
                                                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                
                                                                <!-- Dose -->
                                                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                                                    <TextBlock Text="Dose | الجرعة" FontSize="11" Foreground="{DynamicResource SubtextColor}" Margin="0,0,0,4"/>
                                                                    <ui:TextBox Height="34" Text="{Binding Dose, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. 1 tab / 5ml"/>
                                                                </StackPanel>
                                                                
                                                                <!-- Form -->
                                                                <StackPanel Grid.Column="1" Margin="6,0,6,0">
                                                                    <TextBlock Text="Form | الشكل" FontSize="11" Foreground="{DynamicResource SubtextColor}" Margin="0,0,0,4"/>
                                                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="34" IsEditable="True" Text="{Binding Type, UpdateSourceTrigger=PropertyChanged}">
                                                                        <ComboBoxItem Content="Tablet | حبوب"/>
                                                                        <ComboBoxItem Content="Capsule | كبسولة"/>
                                                                        <ComboBoxItem Content="Syrup | شراب"/>
                                                                        <ComboBoxItem Content="Injection | حقنة"/>
                                                                        <ComboBoxItem Content="Drops | قطرات"/>
                                                                        <ComboBoxItem Content="Ointment | مرهم"/>
                                                                        <ComboBoxItem Content="Inhaler | بخاخ"/>
                                                                    </ComboBox>
                                                                </StackPanel>
                                                                
                                                                <!-- Frequency -->
                                                                <StackPanel Grid.Column="2" Margin="6,0,6,0">
                                                                    <TextBlock Text="Frequency | التكرار" FontSize="11" Foreground="{DynamicResource SubtextColor}" Margin="0,0,0,4"/>
                                                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="34" IsEditable="True" Text="{Binding Time, UpdateSourceTrigger=PropertyChanged}">
                                                                        <ComboBoxItem Content="1x Daily | مرة يومياً"/>
                                                                        <ComboBoxItem Content="2x Daily (12h) | مرتين يومياً"/>
                                                                        <ComboBoxItem Content="3x Daily (8h) | 3 مرات يومياً"/>
                                                                        <ComboBoxItem Content="4x Daily (6h) | 4 مرات يومياً"/>
                                                                        <ComboBoxItem Content="Every 4 hours | كل 4 ساعات"/>
                                                                        <ComboBoxItem Content="As needed (PRN) | عند الحاجة"/>
                                                                        <ComboBoxItem Content="Before bed | قبل النوم"/>
                                                                    </ComboBox>
                                                                </StackPanel>
                                                                
                                                                <!-- Note -->
                                                                <StackPanel Grid.Column="3" Margin="6,0,0,0">
                                                                    <TextBlock Text="Note | ملاحظة" FontSize="11" Foreground="{DynamicResource SubtextColor}" Margin="0,0,0,4"/>
                                                                    <ui:TextBox Height="34" Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. After meals"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ui:Card>

                                <!-- 6. Labs & Investigations -->
                                <ui:Card x:Name="CardLabs" Margin="0,0,0,12" Visibility="{Binding ShowInvestigation, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="&#xF191;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Labs &amp; Investigations | التحاليل" Style="{StaticResource Header2}"/>
                                        </StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="LabsComboBox" Grid.Column="0" Style="{StaticResource MaterialDesignOutlinedComboBox}" IsEditable="True" ItemsSource="{Binding InvestigationList}" Text="{Binding SelectedInvestigation, UpdateSourceTrigger=PropertyChanged}" Height="34" PreviewKeyDown="ComboBox_PreviewKeyDown"/>
                                            <ui:Button Grid.Column="1" Appearance="Secondary" Content="Add" Command="{Binding AddInvestigationCommand}" Padding="15,0" Margin="8,0,0,0" Height="34"/>
                                        </Grid>
                                        
                                        <!-- Investigations Items List -->
                                        <ItemsControl ItemsSource="{Binding AddedInvestigations}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1.5" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <!-- Left: Attachment Status & Name -->
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <TextBlock Text="&#xF191;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource PrimaryColor}" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextColor}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                                
                                                                <!-- File Attachment Chip -->
                                                                <Grid VerticalAlignment="Center">
                                                                    <!-- Case A: No File -->
                                                                    <Border Background="#334155" CornerRadius="4" Padding="6,3" Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                            <TextBlock Text="No file" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    
                                                                    <!-- Case B: Attached File -->
                                                                    <Button Style="{StaticResource LinkButton}" Content="{Binding AttachmentName}" Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding AttachmentPath}" Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibilityConverter}}" FontSize="11" Foreground="#10B981" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </StackPanel>
                                                            
                                                            <!-- Right: Action Buttons -->
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Button Style="{StaticResource IconButton}" Tag="&#xE294;" ToolTip="Scan Document" Command="{Binding DataContext.ScanDocumentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Foreground="{DynamicResource SecondaryColor}" FontSize="14" Margin="0,0,6,0"/>
                                                                <Button Style="{StaticResource IconButton}" Tag="&#xE71B;" ToolTip="Attach File" Command="{Binding DataContext.UploadInvestigationFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Foreground="{DynamicResource PrimaryColor}" FontSize="14" Margin="0,0,6,0"/>
                                                                <Button Style="{StaticResource IconButton}" Tag="&#xE749;" ToolTip="Print Attachment" Command="{Binding DataContext.PrintClinicalAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Foreground="{DynamicResource TextColor}" FontSize="14" Margin="0,0,6,0" Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                <Button Style="{StaticResource IconButton}" Tag="&#xE711;" ToolTip="Remove" Command="{Binding DataContext.RemoveInvestigationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Foreground="{DynamicResource AccentColor}" FontSize="14"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ui:Card>

                                <!-- 7. Imaging & Radiology -->
                                <ui:Card x:Name="CardImaging" Margin="0,0,0,12" Visibility="{Binding ShowInvestigation, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE91B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Imaging &amp; Radiology | الأشعة" Style="{StaticResource Header2}" Margin="0"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="ImagingComboBox" Grid.Column="0" Style="{StaticResource MaterialDesignOutlinedComboBox}" IsEditable="True" ItemsSource="{Binding ImagingList}" Text="{Binding SelectedImaging, UpdateSourceTrigger=PropertyChanged}" Height="34" PreviewKeyDown="ComboBox_PreviewKeyDown"/>
                                            <ui:Button Grid.Column="1" Appearance="Secondary" Content="Add" Command="{Binding AddImagingCommand}" Padding="15,0" Margin="8,0,0,0" Height="34"/>
                                        </Grid>
                                        
                                        <!-- Imaging Items List -->
                                        <ItemsControl ItemsSource="{Binding AddedImagings}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1.5" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <!-- Left: Attachment Status & Name -->
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <TextBlock Text="&#xE91B;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource PrimaryColor}" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextColor}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                                
                                                                <!-- File Attachment Chip -->
                                                                <Grid VerticalAlignment="Center">
                                                                    <!-- Case A: No File -->
                                                                    <Border Background="#334155" CornerRadius="4" Padding="6,3" Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                            <TextBlock Text="No file" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    
                                                                    <!-- Case B: Attached File -->
                                                                    <Button Style="{StaticResource LinkButton}" Content="{Binding AttachmentName}" Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding AttachmentPath}" Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibilityConverter}}" FontSize="11" Foreground="#10B981" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </StackPanel>
                                                            
                                                            <!-- Right: Action Buttons -->
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Button Style="{StaticResource IconButton}" Tag="&#xE294;" ToolTip="Scan Document" Command="{Binding DataContext.ScanDocumentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Foreground="{DynamicResource SecondaryColor}" FontSize="14" Margin="0,0,6,0"/>
                                                                <Button Style="{StaticResource IconButton}" Tag="&#xE71B;" ToolTip="Attach File" Command="{Binding DataContext.UploadImagingFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Foreground="{DynamicResource PrimaryColor}" FontSize="14" Margin="0,0,6,0"/>
                                                                <Button Style="{StaticResource IconButton}" Tag="&#xE749;" ToolTip="Print Attachment" Command="{Binding DataContext.PrintClinicalAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Foreground="{DynamicResource TextColor}" FontSize="14" Margin="0,0,6,0" Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                <Button Style="{StaticResource IconButton}" Tag="&#xE711;" ToolTip="Remove" Command="{Binding DataContext.RemoveImagingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Foreground="{DynamicResource AccentColor}" FontSize="14"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ui:Card>

                                <!-- 8. Treatment Plan / Notes -->
                                <ui:Card x:Name="CardPlan" Margin="0,0,0,12">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Treatment Plan / Notes | خطة العلاج والملاحظات" Style="{StaticResource Header2}" Margin="0"/>
                                            </StackPanel>
                                            <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}" Tag="&#xE720;" Command="{Binding SimulateVoiceInputCommand}" CommandParameter="TreatmentPlan"/>
                                        </Grid>
                                        <ui:TextBox Text="{Binding TreatmentPlan, UpdateSourceTrigger=PropertyChanged}" Height="75" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                                        
                                        <!-- Quick Narrative Chips for Treatment Plan -->
                                        <WrapPanel Margin="0,8,0,0">
                                            <Button Style="{StaticResource ChipButton}" Content="Bed rest | الراحة التامة" Command="{Binding AppendTextCommand}" CommandParameter="Plan:Bed rest / الراحة التامة والتعافي"/>
                                            <Button Style="{StaticResource ChipButton}" Content="Drink fluids | سوائل دافئة" Command="{Binding AppendTextCommand}" CommandParameter="Plan:Drink plenty of warm fluids / الإكثار من شرب السوائل الدافئة والماء"/>
                                            <Button Style="{StaticResource ChipButton}" Content="Follow-up | مراجعة" Command="{Binding AppendTextCommand}" CommandParameter="Plan:Follow up in 3 days / مراجعة العيادة بعد 3 أيام عند عدم التحسن"/>
                                            <Button Style="{StaticResource ChipButton}" Content="Avoid fat | تجنب الدهون" Command="{Binding AppendTextCommand}" CommandParameter="Plan:Avoid fatty foods / تجنب تناول الأطعمة الدسمة والمقلية"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </ui:Card>

                                <!-- 9. Obstetrics & Gynecology (Conditional) -->
                                <ui:Card Margin="0,0,0,12" Visibility="{Binding ShowObstetricsCard, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="Obstetrics &amp; Gynecology | التوليد والنساء" Style="{StaticResource Header2}"/>
                                        <WrapPanel Margin="0,5,0,0">
                                            <StackPanel Margin="0,0,15,8" Width="110">
                                                <TextBlock Text="LMP" Style="{StaticResource Subheading}"/>
                                                <DatePicker SelectedDate="{Binding ObLMP}" Height="34"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,15,8" Width="110">
                                                <TextBlock Text="EDD" Style="{StaticResource Subheading}"/>
                                                <DatePicker SelectedDate="{Binding ObEDD}" Height="34"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,15,8" Width="70">
                                                <TextBlock Text="Gravida" Style="{StaticResource Subheading}"/>
                                                <TextBox Style="{StaticResource CompactVitalInput}" Text="{Binding ObGravida}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,15,8" Width="70">
                                                <TextBlock Text="Para" Style="{StaticResource Subheading}"/>
                                                <TextBox Style="{StaticResource CompactVitalInput}" Text="{Binding ObPara}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,15,8" Width="70">
                                                <TextBlock Text="Abortion" Style="{StaticResource Subheading}"/>
                                                <TextBox Style="{StaticResource CompactVitalInput}" Text="{Binding ObAbortion}"/>
                                            </StackPanel>
                                        </WrapPanel>
                                    </StackPanel>
                                </ui:Card>

                                <!-- 10. Review of Systems (ROS) -->
                                <ui:Card Margin="0,0,0,12" Visibility="{Binding ShowSystemReviewSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="Review of Systems (ROS) | فحص أجهزة الجسم" Style="{StaticResource Header2}"/>
                                        <StackPanel>
                                            <WrapPanel>
                                                <CheckBox Content="CVS" IsChecked="{Binding SysShowCVS}" Margin="0,0,20,8"/>
                                                <CheckBox Content="Respiratory" IsChecked="{Binding SysShowResp}" Margin="0,0,20,8"/>
                                                <CheckBox Content="GI" IsChecked="{Binding SysShowGI}" Margin="0,0,20,8"/>
                                                <CheckBox Content="Neurological" IsChecked="{Binding SysShowCNS}" Margin="0,0,20,8"/>
                                                <CheckBox Content="Other systems" IsChecked="{Binding SysShowOther}" Margin="0,0,20,8"/>
                                            </WrapPanel>
                                            <Grid Margin="0,10,0,0">
                                                <StackPanel>
                                                    <ui:TextBox Text="{Binding SysReviewCVS, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="CVS Findings..." Margin="0,0,0,8" Visibility="{Binding SysShowCVS, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    <ui:TextBox Text="{Binding SysReviewResp, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Respiratory..." Margin="0,0,0,8" Visibility="{Binding SysShowResp, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    <ui:TextBox Text="{Binding SysReviewGI, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="GI..." Margin="0,0,0,8" Visibility="{Binding SysShowGI, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    <ui:TextBox Text="{Binding SysReviewCNS, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Neurological..." Margin="0,0,0,8" Visibility="{Binding SysShowCNS, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    <ui:TextBox Text="{Binding SysReviewOther, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Other..." Margin="0,0,0,8" Visibility="{Binding SysShowOther, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </ui:Card>

                                <!-- 11. Patient History & Lifestyle -->
                                <ui:Card x:Name="CardHistory" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Patient History &amp; Lifestyle | التاريخ المرضي" Style="{StaticResource Header2}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,4,0,0">
                                            <TextBlock Text="Allergies | الحساسية" Style="{StaticResource Subheading}"/>
                                            <ui:TextBox Text="{Binding PatientAllergy, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter allergies..." Margin="0,0,0,10"/>
                                            
                                            <TextBlock Text="Smoking | التدخين" Style="{StaticResource Subheading}"/>
                                            <ui:TextBox Text="{Binding PatientSmoking, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. 10 cig/day for 5 yrs" Margin="0,0,0,10"/>
                                            
                                            <TextBlock Text="Alcohol | الكحول" Style="{StaticResource Subheading}"/>
                                            <ui:TextBox Text="{Binding PatientAlcohol, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. None, Occasional" Margin="0,0,0,5"/>
                                        </StackPanel>
                                    </StackPanel>
                                </ui:Card>

                                <!-- 12. Past Visits History -->
                                <Border Style="{StaticResource AccentCardBorder}" Padding="15">
                                    <Expander Header="Past Visits History | سجل الزيارات" Style="{StaticResource {x:Type Expander}}" ExpandDirection="Down">
                                        <ScrollViewer Height="220" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding VisitHistory}" Margin="0,10,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,8">
                                                            <StackPanel>
                                                                <Grid>
                                                                    <TextBlock Text="{Binding VisitDate, StringFormat='\{0:dd/MM/yyyy HH:mm\}'}" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}"/>
                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                                        <Button Content="Print Report" Style="{StaticResource LinkButton}" Command="{Binding DataContext.PrintVisitReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                                <TextBlock Text="{Binding Diagnosis, StringFormat='Diagnosis: {0}'}" FontSize="11" Margin="0,4,0,2" Foreground="{DynamicResource TextColor}" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding ChiefComplaint, StringFormat='Complaint: {0}'}" FontSize="11" Margin="0,0,0,2" Foreground="{DynamicResource SubtextColor}" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Prescription, StringFormat='Rx: {0}'}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryColor}" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Expander>
                                </Border>
                                </StackPanel>
                        </ScrollViewer>

                        <!-- COL 2: RIGHT PATIENT DOSSIER PANEL -->
                        <Border Grid.Column="2" Background="{DynamicResource BottomBarBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1,0,0,0" Margin="0,0,-12,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                                <StackPanel>
                                    <!-- Patient Avatar + Name -->
                                    <StackPanel HorizontalAlignment="Center" Margin="0,8,0,16">
                                        <Border Width="52" Height="52" CornerRadius="26" HorizontalAlignment="Center" Margin="0,0,0,10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#8B5CF6" Offset="0"/> <!-- Purple -->
                                                    <GradientStop Color="#EC4899" Offset="1"/> <!-- Pink -->
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="{Binding PatientInitials}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding CurrentPatient.Name}" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,2"/>
                                    </StackPanel>

                                    <!-- Demographics Grid -->
                                    <Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="8" Padding="14" Margin="0,0,0,12" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <TextBlock Text="ID Patient" FontSize="12" Foreground="{DynamicResource SubtextColor}"/>
                                                <TextBlock Text="{Binding CurrentPatient.PatientId}" FontSize="12" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,10">
                                                <TextBlock Text="Gender" FontSize="12" Foreground="{DynamicResource SubtextColor}"/>
                                                <TextBlock Text="{Binding CurrentPatient.Gender}" FontSize="12" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,10">
                                                <TextBlock Text="Age" FontSize="12" Foreground="{DynamicResource SubtextColor}"/>
                                                <TextBlock Text="{Binding CurrentPatient.Age, StringFormat='{}{0} years'}" FontSize="12" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,10">
                                                <TextBlock Text="Visit date" FontSize="12" Foreground="{DynamicResource SubtextColor}"/>
                                                <TextBlock Text="{Binding PatientVisitDate}" FontSize="12" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,10">
                                                <TextBlock Text="Phone" FontSize="12" Foreground="{DynamicResource SubtextColor}"/>
                                                <TextBlock Text="{Binding CurrentPatient.Phone}" FontSize="12" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid>
                                                <TextBlock Text="Blood Group" FontSize="12" Foreground="{DynamicResource SubtextColor}" VerticalAlignment="Center"/>
                                                <Border CornerRadius="12" Background="#EF4444" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <TextBox Style="{StaticResource ModernTextBox}" BorderThickness="0" Padding="0" Background="Transparent"
                                                             Text="{Binding CurrentPatient.BloodGroup, UpdateSourceTrigger=PropertyChanged}" 
                                                             FontSize="11" FontWeight="Bold" Foreground="White" Width="30" TextAlignment="Center"
                                                             Tag="O+"/>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Medical Info Card -->
                                    <Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="8" Padding="14" Margin="0,0,0,12" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Medical Info" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,0,8"/>
                                            <TextBox Style="{StaticResource ModernTextBox}" BorderThickness="0" Padding="0" Background="Transparent"
                                                     Text="{Binding CurrentPatient.Notes, UpdateSourceTrigger=PropertyChanged}" 
                                                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Height="60"
                                                     Tag="Enter medical history, chronic diseases, etc..."/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Print Actions -->
                                    <Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="8" Padding="14,16" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Quick Actions" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,0,12"/>
                                            <Button Style="{StaticResource SecondaryButton}" Foreground="White" BorderBrush="{DynamicResource BorderColor}" Command="{Binding PrintActiveRxCommand}" Height="38" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Print Rx (A5)" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource SecondaryButton}" Foreground="White" BorderBrush="{DynamicResource BorderColor}" Command="{Binding PrintActiveVisitReportCommand}" Height="38" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE246;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Print Summary (A4)" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource SecondaryButton}" Foreground="White" BorderBrush="{DynamicResource BorderColor}" Command="{Binding OpenAddPatientModalCommand}" Height="38" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE109;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Add Note" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource ModernButton}" Command="{Binding OpenStartNewVisitWindowCommand}" Height="38" HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Schedule Visit" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </materialDesign:DialogHost>

        <!-- Overlay drag drop canvases & popup modals -->
        <!-- DragPreview Canvas -->
        <Canvas x:Name="DragPreviewCanvas" IsHitTestVisible="False" Background="Transparent" Visibility="Collapsed">
            <Border x:Name="DragPreviewBorder" BorderBrush="{DynamicResource PrimaryColor}" BorderThickness="1.5" CornerRadius="8" Opacity="0.95" Background="{DynamicResource CardBackgroundColor}" IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.15" ShadowDepth="3"/>
                </Border.Effect>
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="15">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DragPreviewText" Text="Patient Name" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextColor}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Canvas>

        <!-- Switch Doctor Password Modal -->
        <Grid Background="#80000000" Visibility="{Binding ShowSwitchDoctorPasswordModal, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5" CornerRadius="12" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.3" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding SelectedSwitchDoctor.Name, StringFormat='Switch Doctor to: {0}'}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,0,15"/>
                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <TextBlock Text="Password" FontSize="11" Foreground="{DynamicResource SubtextColor}" Margin="0,0,0,4"/>
                        <PasswordBox Style="{StaticResource ModernPasswordBox}" helpers:PasswordHelper.Attach="True" helpers:PasswordHelper.Password="{Binding SwitchDoctorPasswordAttempt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding SwitchDoctorErrorMessage}" Foreground="#EF4444" FontSize="11"/>
                    </StackPanel>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource SecondaryButton}" Content="Cancel" Command="{Binding CancelSwitchDoctorPasswordCommand}" Margin="0,0,5,0" Height="36"/>
                        <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="Authenticate" Command="{Binding ConfirmSwitchDoctorPasswordCommand}" IsDefault="True" Margin="5,0,0,0" Height="36"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Add Patient Modal -->
        <Grid Background="#80000000" Visibility="{Binding ShowAddPatientModal, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5" CornerRadius="12" Width="680" Height="480" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.3" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="إضافة مريض جديد (Register New Patient)" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" HorizontalAlignment="Right" Margin="0,0,0,15"/>
                    <ScrollViewer Grid.Row="1" Margin="0,0,0,15" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Left Column -->
                            <StackPanel Grid.Column="0" Margin="0,0,12,0" FlowDirection="RightToLeft">
                                <TextBlock Text="الجنس" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" SelectedValuePath="Content" SelectedValue="{Binding NewPatientGender}" Height="36" Margin="0,0,0,12" FlowDirection="RightToLeft">
                                    <ComboBoxItem Content="ذكر"/>
                                    <ComboBoxItem Content="أنثى"/>
                                </ComboBox>
                                <TextBlock Text="زمرة الدم" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <ui:TextBox Text="{Binding NewPatientBloodGroup}" PlaceholderText="O+, A-, etc." Margin="0,0,0,12" HorizontalContentAlignment="Right"/>
                                <TextBlock Text="الحالة الاجتماعية" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <ui:TextBox Text="{Binding NewPatientMaritalStatus}" PlaceholderText="أعزب، متزوج..." Margin="0,0,0,12" HorizontalContentAlignment="Right"/>
                                <TextBlock Text="العنوان السكني" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <ui:TextBox Text="{Binding NewPatientAddress}" PlaceholderText="المنطقة والشارع" Margin="0,0,0,12" HorizontalContentAlignment="Right"/>
                                <TextBlock Text="ملف إضافي (التحليل/الأشعة)" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox Grid.Column="0" Text="{Binding NewPatientFileName, Mode=OneWay}" IsReadOnly="True" PlaceholderText="لم يتم اختيار ملف" Margin="0,0,6,0"/>
                                    <ui:Button Grid.Column="1" Appearance="Secondary" Content="رفع ملف" Command="{Binding UploadNewPatientFileCommand}" Padding="15,0" Height="36"/>
                                </Grid>
                                <Border Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,0,10" Visibility="{Binding NewPatientFiles, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Foreground="#0284C7" Margin="0,0,6,0"/>
                                        <Button Grid.Column="1" Content="{Binding NewPatientFileName}" Style="{StaticResource NavButton}" Padding="0" HorizontalContentAlignment="Left" Foreground="#0284C7" FontSize="11" FontWeight="SemiBold" Command="{Binding OpenNewPatientFileCommand}" CommandParameter="{Binding NewPatientFiles}"/>
                                        <Button Grid.Column="2" Style="{StaticResource NavButton}" Width="16" Height="16" Tag="&#xE711;" ToolTip="حذف الملف" Padding="0" Foreground="#EF4444" FontSize="8" Command="{Binding RemoveNewPatientFileCommand}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            <!-- Right Column -->
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" FlowDirection="RightToLeft">
                                <TextBlock Text="* الاسم" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <ui:TextBox Text="{Binding NewPatientName, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="اسم المريض الثلاثي" Margin="0,0,0,12" HorizontalContentAlignment="Right"/>
                                <TextBlock Text="* العمر (سنوات)" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <ui:TextBox Text="{Binding NewPatientAge, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="العمر بالسنوات" Margin="0,0,0,12" HorizontalContentAlignment="Right"/>
                                <TextBlock Text="العمر (أشهر)" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <ui:TextBox Text="{Binding NewPatientAgeMonths, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="أشهر" Margin="0,0,0,12" HorizontalContentAlignment="Right"/>
                                <TextBlock Text="تاريخ الولادة" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <DatePicker SelectedDate="{Binding NewPatientBirthDate}" Height="36" Margin="0,0,0,12" FlowDirection="RightToLeft"/>
                                <TextBlock Text="رقم الهاتف" FontSize="11" Foreground="{DynamicResource SubtextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <ui:TextBox Text="{Binding NewPatientPhone, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="رقم الهاتف" Margin="0,0,0,12" HorizontalContentAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                    <!-- Buttons -->
                    <StackPanel Grid.Row="2">
                        <TextBlock Text="{Binding AddPatientValidationMessage}" Foreground="#EF4444" FontSize="12" HorizontalAlignment="Right" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0" Appearance="Secondary" Content="إلغاء" Command="{Binding CancelAddPatientCommand}" Height="38" Margin="0,0,5,0" HorizontalAlignment="Stretch"/>
                            <ui:Button Grid.Column="1" Appearance="Primary" Content="حفظ وتأكيد الدخول" Command="{Binding SaveAddPatientCommand}" Height="38" Margin="5,0,0,0" HorizontalAlignment="Stretch"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
