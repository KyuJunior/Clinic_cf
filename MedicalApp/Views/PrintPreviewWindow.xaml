<Window x:Class="MedicalApp.Views.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print Layout Settings &amp; Preview" Height="780" Width="920"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResize">
    
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/> <!-- Left Panel: Print Settings -->
            <ColumnDefinition Width="*"/>   <!-- Right Panel: Live Document Preview -->
        </Grid.ColumnDefinitions>

        <!-- Column 0: Print Settings Sidebar -->
        <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,15,0" VerticalAlignment="Stretch">
            <StackPanel Margin="5">
                <TextBlock Text="Print Options" Style="{StaticResource Header2}" Margin="0,0,0,5"/>
                <TextBlock Text="Configure printer properties and preferences." Style="{StaticResource Subheading}" Margin="0,0,0,20"/>

                <!-- Printer Selection -->
                <TextBlock Text="Printer" FontWeight="Bold" Foreground="{DynamicResource TextColor}" Margin="0,0,0,5"/>
                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" x:Name="PrinterComboBox" Height="36" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                <!-- Orientation -->
                <TextBlock Text="Orientation" FontWeight="Bold" Foreground="{DynamicResource TextColor}" Margin="0,0,0,5"/>
                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" x:Name="OrientationComboBox" Height="36" Margin="0,0,0,15" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Portrait" IsSelected="True"/>
                    <ComboBoxItem Content="Landscape"/>
                </ComboBox>

                <!-- Copies -->
                <TextBlock Text="Copies" FontWeight="Bold" Foreground="{DynamicResource TextColor}" Margin="0,0,0,5"/>
                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" x:Name="CopiesComboBox" Height="36" Margin="0,0,0,15" VerticalContentAlignment="Center" IsEditable="True">
                    <ComboBoxItem Content="1" IsSelected="True"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="4"/>
                    <ComboBoxItem Content="5"/>
                </ComboBox>

                <!-- Color Mode -->
                <TextBlock Text="Color Mode" FontWeight="Bold" Foreground="{DynamicResource TextColor}" Margin="0,0,0,5"/>
                <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}" x:Name="ColorComboBox" Height="36" Margin="0,0,0,25" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Color" IsSelected="True"/>
                    <ComboBoxItem Content="Black &amp; White"/>
                </ComboBox>

                <!-- Action Buttons -->
                <Button Style="{StaticResource ModernButton}" Content="Print" Click="Print_Click" Height="40" Margin="0,0,0,10" HorizontalAlignment="Stretch"/>
                <Button Style="{StaticResource ModernButton}" Content="Cancel" Click="Cancel_Click" Background="#EF4444" BorderBrush="#EF4444" Height="38" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <!-- Column 1: Live Document Preview -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Background="{DynamicResource CardBackgroundColor}" VerticalAlignment="Stretch">
            <FlowDocumentPageViewer Name="DocViewer" Zoom="85"/>
        </Border>
    </Grid>
</Window>
