<UserControl x:Class="MedicalApp.Views.PrintSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="Transparent">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="10,15,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Back Navigation Header -->
            <RowDefinition Height="*"/>    <!-- Settings & Preview Columns -->
        </Grid.RowDefinitions>

        <!-- Back Button Header -->
        <Button Grid.Row="0" HorizontalAlignment="Left" Margin="0,0,0,15"
                Style="{StaticResource NavButton}" Padding="12,7" 
                Tag="&#xE72B;" Content="Back to Dashboard"
                Command="{Binding NavigateBackCommand}"/>

        <!-- Main Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/> <!-- Calibration Controls -->
                <ColumnDefinition Width="*"/>   <!-- Live A5 Layout Preview -->
            </Grid.ColumnDefinitions>

            <!-- Column 0: Calibration Controls -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,15,0" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="5">
                        <TextBlock Text="Print Template Calibration" Style="{StaticResource Header2}" Margin="0,0,0,5"/>
                        <TextBlock Text="Adjust print alignment offsets and backgrounds for pre-printed A5 prescription sheets." Style="{StaticResource Subheading}" Margin="0,0,0,20" TextWrapping="Wrap"/>

                        <!-- Image Upload section -->
                        <TextBlock Text="Prescription Background Template" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding RxBackgroundPath, Mode=OneWay}" IsReadOnly="True" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11"/>
                            <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="Upload A5 Image" Command="{Binding UploadImageCommand}" Padding="15,8"/>
                        </Grid>

                        <CheckBox Content="Print background image on paper" IsChecked="{Binding PrintBackground}" Margin="0,0,0,20" FontWeight="SemiBold"/>

                        <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,0,0,15"/>

                        <!-- Sliders for Patient Name -->
                        <TextBlock Text="Patient Name Coordinates" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,3"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,5,0">
                                <TextBlock Text="{Binding PatientNameX, StringFormat='X: \{0:F0\} px'}" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                <Slider Minimum="0" Maximum="300" Value="{Binding PatientNameX}" TickFrequency="5" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="{Binding PatientNameY, StringFormat='Y: \{0:F0\} px'}" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                <Slider Minimum="0" Maximum="450" Value="{Binding PatientNameY}" TickFrequency="5" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                        </Grid>

                        <!-- Sliders for Patient Age & Gender -->
                        <TextBlock Text="Age &amp; Gender Coordinates" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,3"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,5,0">
                                <TextBlock Text="{Binding PatientAgeGenderX, StringFormat='X: \{0:F0\} px'}" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                <Slider Minimum="0" Maximum="300" Value="{Binding PatientAgeGenderX}" TickFrequency="5" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="{Binding PatientAgeGenderY, StringFormat='Y: \{0:F0\} px'}" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                <Slider Minimum="0" Maximum="450" Value="{Binding PatientAgeGenderY}" TickFrequency="5" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                        </Grid>

                        <!-- Sliders for Date -->
                        <TextBlock Text="Prescription Date Coordinates" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,3"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,5,0">
                                <TextBlock Text="{Binding PatientDateX, StringFormat='X: \{0:F0\} px'}" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                <Slider Minimum="0" Maximum="300" Value="{Binding PatientDateX}" TickFrequency="5" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="{Binding PatientDateY, StringFormat='Y: \{0:F0\} px'}" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                <Slider Minimum="0" Maximum="450" Value="{Binding PatientDateY}" TickFrequency="5" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                        </Grid>

                        <!-- Sliders for Rx Symbol -->
                        <Grid Margin="0,0,0,3">
                            <TextBlock Text="Rx Symbol Header" FontWeight="Bold" Foreground="{StaticResource TextColor}" VerticalAlignment="Center"/>
                            <CheckBox Content="Show" IsChecked="{Binding ShowRxSymbol}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,12" Visibility="{Binding ShowRxSymbol, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,5,0">
                                <TextBlock Text="{Binding RxSymbolX, StringFormat='X: \{0:F0\} px'}" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                <Slider Minimum="0" Maximum="300" Value="{Binding RxSymbolX}" TickFrequency="5" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="{Binding RxSymbolY, StringFormat='Y: \{0:F0\} px'}" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                <Slider Minimum="0" Maximum="450" Value="{Binding RxSymbolY}" TickFrequency="5" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                        </Grid>

                        <!-- Sliders for Drugs list -->
                        <TextBlock Text="Drugs List Coordinates" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,3"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,5,0">
                                <TextBlock Text="{Binding DrugsX, StringFormat='X: \{0:F0\} px'}" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                <Slider Minimum="0" Maximum="300" Value="{Binding DrugsX}" TickFrequency="5" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="{Binding DrugsY, StringFormat='Y: \{0:F0\} px'}" FontSize="11" Foreground="{StaticResource SubtextColor}"/>
                                <Slider Minimum="50" Maximum="450" Value="{Binding DrugsY}" TickFrequency="5" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,0,0,20">
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Medication Font Size" FontSize="12" Foreground="{StaticResource SubtextColor}"/>
                                <TextBlock Text="{Binding FontSize, StringFormat='\{0:F0\} pt'}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Slider Minimum="10" Maximum="24" Value="{Binding FontSize}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        </StackPanel>

                        <Button Style="{StaticResource ModernButton}" Content="Save Calibration Settings" Command="{Binding SaveSettingsCommand}" Height="40" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Column 1: Live A5 Layout Preview -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,0,0" Background="#F1F5F9" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Live A5 Calibration Grid Preview" Style="{StaticResource Header2}" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                    <!-- Simulated A5 Sheet -->
                    <Border Grid.Row="1" Width="350" Height="495" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" CornerRadius="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.15" ShadowDepth="4"/>
                        </Border.Effect>
                        <Grid>
                            <Canvas ClipToBounds="True">
                                <!-- Background Image Overlay (faded preview) -->
                                <Image Source="{Binding RxBackgroundPath}" Width="350" Height="495" Stretch="Fill" Opacity="0.45"/>

                                <!-- Simulated Patient Name -->
                                <TextBlock Canvas.Left="{Binding PatientNameX}" Canvas.Top="{Binding PatientNameY}" 
                                           Text="Patient Name: John Doe" FontSize="11" FontWeight="SemiBold" Foreground="#1E293B"/>

                                <!-- Simulated Date -->
                                <TextBlock Canvas.Left="{Binding PatientDateX}" Canvas.Top="{Binding PatientDateY}" 
                                           Text="Date: 07/07/2026" FontSize="9" Foreground="#64748B"/>

                                <!-- Simulated Age & Gender -->
                                <TextBlock Canvas.Left="{Binding PatientAgeGenderX}" Canvas.Top="{Binding PatientAgeGenderY}" 
                                           Text="Age: 45 yrs | Gender: Male" FontSize="9" Foreground="#64748B"/>

                                <!-- Simulated Rx Header -->
                                <TextBlock Canvas.Left="{Binding RxSymbolX}" Canvas.Top="{Binding RxSymbolY}" 
                                           Text="Rx" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" 
                                           Visibility="{Binding ShowRxSymbol, Converter={StaticResource BoolToVis}}"/>

                                <!-- Simulated Prescription/Drugs Block -->
                                <StackPanel Canvas.Left="{Binding DrugsX}" Canvas.Top="{Binding DrugsY}">
                                    <TextBlock Text="1. Amoxicillin 500mg (1x3 Daily)" FontSize="{Binding FontSize}" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    <TextBlock Text="2. Paracetamol 1000mg (As needed for pain)" FontSize="{Binding FontSize}" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Canvas>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
